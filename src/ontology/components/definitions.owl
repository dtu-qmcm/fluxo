AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000041> "A set of methods used to measure the rates of intracellular metabolic reactions in living cells using data from isotope labeling experiments")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000041> "I-MFA")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000041> "isotope-based metabolic flux analysis")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000041> <http://purl.obolibrary.org/obo/MFAO_0000040>)

