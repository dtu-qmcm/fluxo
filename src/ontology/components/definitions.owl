AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000042> "A method for estimating metabolic fluxes by tracking from the distribution of 13C isotopes in metabolites.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000042> "13C-MFA")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000042> "13C-based metabolic flux analysis")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000042> "13C metabolic flux analysis")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000042> <http://purl.obolibrary.org/obo/MFAO_0000041>)

