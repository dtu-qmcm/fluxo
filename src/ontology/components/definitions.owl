AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000055> "The percentage of molecules in a given metabolite pool that contain one or more isotopic labels from a tracer.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000055> "fractional enrichment")
