AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000052> "A charged dissociation product of a molecule generated during mass spectrometry, providing specific positional labeling information.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000052> "Daughter ion")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000052> "fragment ion")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000052> <http://purl.obolibrary.org/obo/CHEBI_25367>)

