AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000051> "One labeling experiment where a single tracer or tracer mixture is supplied")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000051> "single labeling experiment")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000051> <http://purl.obolibrary.org/obo/MFAO_0000049>)

