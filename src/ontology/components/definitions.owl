AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000046> "Approaches to increase the information content of an isotope labeling experiment")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000046> "isotope labeling experiment design")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000046> <http://edamontology.org/topic_3678>)

