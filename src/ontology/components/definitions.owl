# Class: <http://biomodels.net/SBO/SBO_0000000> (systems biology representation)

AnnotationAssertion(rdfs:label <http://biomodels.net/SBO/SBO_0000000> "systems biology representation")
SubClassOf(<http://biomodels.net/SBO/SBO_0000000> <http://purl.obolibrary.org/obo/IAO_0000030>)

# Class: <http://biomodels.net/SBO/SBO_0000010> (reactant)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://biomodels.net/SBO/SBO_0000010> "Starting metabolite of a metabolic reaction")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://biomodels.net/SBO/SBO_0000010> "reagent")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://biomodels.net/SBO/SBO_0000010> "educt")
AnnotationAssertion(rdfs:label <http://biomodels.net/SBO/SBO_0000010> "reactant")
SubClassOf(<http://biomodels.net/SBO/SBO_0000010> <http://purl.obolibrary.org/obo/CHEBI_25212>)

# Class: <http://biomodels.net/SBO/SBO_0000011> (product)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://biomodels.net/SBO/SBO_0000011> "Product metabolite of a metabolic reaction")
AnnotationAssertion(rdfs:label <http://biomodels.net/SBO/SBO_0000011> "product")
SubClassOf(<http://biomodels.net/SBO/SBO_0000011> <http://purl.obolibrary.org/obo/CHEBI_25212>)

# Class: <http://biomodels.net/SBO/SBO_0000015> (substrate)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://biomodels.net/SBO/SBO_0000015> "Molecule which is acted upon by an enzyme.")
AnnotationAssertion(rdfs:label <http://biomodels.net/SBO/SBO_0000015> "substrate")
SubClassOf(<http://biomodels.net/SBO/SBO_0000015> <http://biomodels.net/SBO/SBO_0000010>)

# Class: <http://biomodels.net/SBO/SBO_0000064> (mathematical expression)

