AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000047> "Computational approaches to targeted improvement of the information gain of an isotope labeling experiment")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000047> "optimal experimental design")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000047> <http://purl.obolibrary.org/obo/MFAO_0000046>)

# Class: <http://purl.obolibrary.org/obo/MFAO_0000048> (tracer selection)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000048> "Strategic choice of isotopic tracer (molecule, labeling position, isotope) based on target pathway thermodynamics and atom transitions.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000048> "tracer selection")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000048> <http://purl.obolibrary.org/obo/MFAO_0000046>)

