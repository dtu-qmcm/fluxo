AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000053> "The ion selected for fragmentation in tandem mass spectrometry (MS/MS).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000053> "Parent ion")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000053> "precursor ion")
