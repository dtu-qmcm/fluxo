# Class: <http://purl.obolibrary.org/obo/FLUXO_0000001> (fluxome)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000001> "The complete set of metabolic fluxes (reaction rates) in a biological system at a given point in time.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000001> "fluxomics")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000001> "fluxome")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000001> <http://purl.obolibrary.org/obo/BFO_0000141>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000002> (fluxomics data)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000002> "the data that contains files to determine the rates of metabolic reactions. It generally includes the model of metabolic networks and experimental data")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000002> "fluxomics data")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000002> <http://purl.obolibrary.org/obo/IAO_0000027>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000003> (internal flux)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000003> "The metabolic flux of a metabolic reaction that occurs within a metabolic network model")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000003> "internal flux")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000003> <http://purl.obolibrary.org/obo/FLUXO_0000123>)
DisjointClasses(<http://purl.obolibrary.org/obo/FLUXO_0000003> <http://purl.obolibrary.org/obo/FLUXO_0000124>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000004> (transport flux)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000004> "The metabolic flux of a transport reaction")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000004> "transport rate")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000004> "transport flux")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000004> <http://purl.obolibrary.org/obo/FLUXO_0000123>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000005> (metabolic reaction)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000005> "biochemical reaction within a biological entity that is part of the metabolism.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000005> "metabolic reaction")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000005> <http://purl.obolibrary.org/obo/FLUXO_0000166>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000006> (reaction bidirectionality)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000006> "A characteristic of a biochemical reaction which may proceed simultaneously in forward and backward direction")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000006> "reaction bidirectionality")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000006> <http://purl.obolibrary.org/obo/BFO_0000019>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000007> (reaction reversibility)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000007> "The property of metabolic reaction to proceed in forward and backward direction")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000007> "reaction bidirectionality")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FLUXO_0000007> "property could be 0 or 1 (True or False)")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000007> "reaction reversibility")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000007> <http://purl.obolibrary.org/obo/BFO_0000019>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000008> (unidirectional reaction)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000008> "A metabolic reaction that solely operates in a single direction, it can be forward or backward direction.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000008> "irreversible reaction")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FLUXO_0000008> "property or class")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000008> "unidirectional reaction")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000008> <http://purl.obolibrary.org/obo/FLUXO_0000005>)
DisjointClasses(<http://purl.obolibrary.org/obo/FLUXO_0000008> <http://purl.obolibrary.org/obo/FLUXO_0000009>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000009> (bidirectional reaction)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000009> "A metabolic reaction that may operate simultaneously in forward and backward direction.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000009> "reversible reaction")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FLUXO_0000009> "property or class")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000009> "bidirectional reaction")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000009> <http://purl.obolibrary.org/obo/FLUXO_0000005>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000010> (reaction direction)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000010> "the direction of the reaction operates")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000010> "reaction direction")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000010> <http://purl.obolibrary.org/obo/BFO_0000019>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000011> (forward reaction)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000011> "the reaction that proceeds from substrates to products")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000011> "forward reaction")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000011> <http://purl.obolibrary.org/obo/FLUXO_0000005>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000012> (backward reaction)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000012> "the reaction that proceeds from products to substrates")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000012> "reverse direction")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000012> "backward reaction")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000012> <http://purl.obolibrary.org/obo/FLUXO_0000005>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000013> (equilibrium)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000013> "the reaction that the rate of the forward reaction equals the rate of the backward reaction")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000013> "equilibrium")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000013> <http://purl.obolibrary.org/obo/FLUXO_0000010>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000014> (source)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000014> "metabolites which are only consumed, typically the substrate(s)")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000014> "source")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000014> <http://purl.obolibrary.org/obo/FLUXO_0000172>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000015> (sink)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000015> "metabolites which are only produced, typically the by-product(s)")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000015> "sink")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000015> <http://purl.obolibrary.org/obo/FLUXO_0000172>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000016> (flux map)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000016> "Quantitative visualization of reaction fluxes within a metabolic network, typically scaled by flux magnitude and annotated with directionality.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000016> "flux map")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000016> <http://purl.obolibrary.org/obo/BFO_0000031>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000017> (fluxotype)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000017> "the specific pattern or distribution of metabolic fluxes within a biological system, such as a cell or organism, under defined conditions.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000017> "flux state")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000017> "metabolic flux phenotype")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000017> "fluxotype")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000017> <http://purl.obolibrary.org/obo/BFO_0000031>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000018> (stoichiometry-based fluxomics method)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000018> "Set of mathemetical approaches for characterizing metabolic states that constrain the possible flux space given a reaction stoichiometry")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000018> "stoichiometry-based fluxomics method")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000018> <http://purl.obolibrary.org/obo/FLUXO_0000162>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000019> (constraint-based fluxomics method)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000019> "Set of mathematical approaches in which the possible fluxes are constrained by a minimum and maximum range of bounds, and further restrictions such as the reaction stoichiometry or objectives")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000019> "constraint-based fluxomics method")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000019> <http://purl.obolibrary.org/obo/FLUXO_0000018>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000020> (flux measurement method)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000020> "A methodology that determines metabolic fluxes within a cell based on empirical data.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000020> "flux measurement method")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000020> <http://purl.obolibrary.org/obo/FLUXO_0000162>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000021> (metabolic flux analysis method)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000021> "Set of approaches that quantitatively estimate/infer metabolic fluxes using a metabolic reaction model, experimental data and computation")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000021> "metabolic flux analysis method")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000021> <http://purl.obolibrary.org/obo/FLUXO_0000020>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000022> (steady state flux solution space)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000022> "Set of all possible flux vectors that are consistent with reaction stoichiometries and a set of flux constraints at metabolic steady state")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000022> "flux polytope")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000022> "flux solution space")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000022> "flux space")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000022> "steady state flux solution space")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000022> <http://purl.obolibrary.org/obo/IAO_0000030>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000023> (flux vector)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000023> "List of the rates of all chemical reactions in a biological network")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000023> "flux distribution")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000023> "flux state")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000023> "flux vector")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000023> <http://purl.obolibrary.org/obo/IAO_0000030>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000024> (stoichiometric reaction model)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000024> "a mathematical representation of a cellular metabolic network that relies on the conservation of mass rather than enzyme kinetics to predict metabolic behavior.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000024> "stoichiometric reaction model")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000024> <http://purl.obolibrary.org/obo/FLUXO_0000057>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000025> (forward flux)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000025> "A rate at which a specific reaction proceeds in the forward direction.")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FLUXO_0000025> "non-negative")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000025> "forward flux")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000025> <http://purl.obolibrary.org/obo/FLUXO_0000123>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000026> (backward flux)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000026> "A rate at which a specific reaction proceeds in the backward direction.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000026> "reverse flux")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FLUXO_0000026> "non-negative")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000026> "backward flux")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000026> <http://purl.obolibrary.org/obo/FLUXO_0000123>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000027> (net flux)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000027> "Difference between the forward and backward flux for a metabolic reaction.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000027> "net rate")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000027> "net flux")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000027> <http://purl.obolibrary.org/obo/FLUXO_0000123>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000028> (exchange flux)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000028> "The minimum of the forward and backward fluxes of a metabolic reaction.")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FLUXO_0000028> "non-negative; This is different from exchange flux in flux balance analysis (make note in ontology)")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000028> "exchange flux")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000028> <http://purl.obolibrary.org/obo/FLUXO_0000123>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000029> (flux ratio)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000029> "Relative proportion of metabolic flow directed into a specific pathway at a divergence point compared to the total flow or an alternative route at that same junction.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000029> "flux ratio")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000029> <http://purl.obolibrary.org/obo/IAO_0000030>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000030> (degrees of freedom in stoichiometry matrix)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000030> "The number of free/independent fluxes that can be varied independently within the network, which is determined by the null space of the stoichiometric matrix. The dimension of this null space gives the number of fluxes needed to define all other fluxes.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000030> "degrees of freedom in stoichiometry matrix")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000030> <http://purl.obolibrary.org/obo/BFO_0000019>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000031> (isomer)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000031> "One of several species (or molecular entities) that have the same atomic composition (molecular formula) but different line formulae or different stereochemical formulae and hence different physical and/or chemical properties.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000031> "isomer")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000031> <http://purl.obolibrary.org/obo/FLUXO_0000170>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000032> (isotopic labeling state)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000032> "The specific distribution of istopic atom in a metabolite pools at specific time")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000032> "metabolite labeling pattern")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000032> "isotopic labeling state")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000032> <http://purl.obolibrary.org/obo/BFO_0000019>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000033> (pseudo-steady state assumption)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000033> "The assumption that the rate of change of an intracellular metabolite concentration is considered negligible, which holds when the metabolic flux through the metabolite pools is much larger than the change in their pool sizes over time")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000033> "Metabolic Pseudo-Steady State")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000033> "pseudo-steady state assumption")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000033> <http://purl.obolibrary.org/obo/BFO_0000031>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000034> (metabolic steady state)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000034> "An idealistic state in which both metabolic fluxes and intracellular metabolite pool sizes are approximately constant over time.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000034> "metabolic steady state")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000034> <http://purl.obolibrary.org/obo/FLUXO_0000177>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000035> (isotopic transient state)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000035> "The dynamic phase of an isotopic labeling experiment where metabolite labeling patterns are not yet constant.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000035> "isotopic transient state")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000035> <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000036> (isotopic steady state)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000036> "A state when the distribution of a stable isotope label within a biological system has become and remains constant over time.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000036> "isotopic steady state")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000036> "isotopic steady state")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000036> <http://purl.obolibrary.org/obo/FLUXO_0000177>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000037> (flux space sampling)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000037> "A stochastic process for characterizing the range of possible/feasible metabolic flux vectors.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000037> "flux state sampling")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000037> "flux space sampling")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000037> <http://purl.obolibrary.org/obo/COB_0000082>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000038> (fluxomics method)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000038> "A technique that determines the possible fluxes of the metabolic reactions in a network")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FLUXO_0000038> "fluxomics method")
SubClassOf(<http://purl.obolibrary.org/obo/FLUXO_0000038> <http://purl.obolibrary.org/obo/COB_0000082>)

# Class: <http://purl.obolibrary.org/obo/FLUXO_0000039> (flux balance analysis)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FLUXO_0000039> "A method that predicts physiological phenotypes allowed by the underlying metabolic model, typically enforced by a metabolic goal (e.g., maximize growth rate).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FLUXO_0000039> "FBA")
