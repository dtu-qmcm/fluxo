AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000050> "Multiple experiments where different isotopic tracers with distinct labeling patterns or tracer mixtures are supplied to resolve overlapping metabolic routes")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000050> "parallel labeling experiments")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000050> <http://purl.obolibrary.org/obo/MFAO_0000049>)

