AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000043> "Isotope-based metabolic flux analysis technique, assuming isotopic steady state and metabolic steady state")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000043> "IST-MFA")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000043> "isotopically stationary metabolic flux analysis")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000043> <http://purl.obolibrary.org/obo/MFAO_0000041>)

# Class: <http://purl.obolibrary.org/obo/MFAO_0000044> (isotopically non-stationary metabolic flux analysis)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000044> "Isotope-based metabolic flux analysis technique, assuming isotopic transient state and metabolic steady state")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000044> "INST-13C-MFA")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000044> "INST-MFA")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000044> "Isotopic Non-Stationary MFA")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000044> "isotopically non-stationary metabolic flux analysis")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000044> <http://purl.obolibrary.org/obo/MFAO_0000045>)

# Class: <http://purl.obolibrary.org/obo/MFAO_0000045> (dynamic Isotope-based metabolic flux analysis)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000045> "Isotope-based metabolic flux analysis technique, assuming both isotopic and metabolic dynamic state")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000045> "dynamic Isotope-based metabolic flux analysis")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000045> <http://purl.obolibrary.org/obo/MFAO_0000041>)

