AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/MFAO_0000049> "An experiment where biological entities are fed stable isotopic tracers (like 13C) which are then distributed throughout the metabolic network via metabolic activity.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/MFAO_0000049> "ILE")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000049> "SIL")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/MFAO_0000049> "fluxomics stable isotope labeling experiment")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/MFAO_0000049> "fluxomics isotope labeling experiment")
SubClassOf(<http://purl.obolibrary.org/obo/MFAO_0000049> <http://purl.obolibrary.org/obo/MSIO_0000182>)

