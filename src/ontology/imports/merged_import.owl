AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/OBCS_0000070> "confidence interval")
SubClassOf(<http://purl.obolibrary.org/obo/OBCS_0000070> <http://purl.obolibrary.org/obo/OBI_0000071>)

