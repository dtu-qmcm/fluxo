AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/OBI_0000470> "Philippe Rocca-Serra")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/OBI_0000470> "Philippe Rocca-Serra")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/OBI_0000470> "mass spectrometry assay")
