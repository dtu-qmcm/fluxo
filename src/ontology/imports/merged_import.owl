AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/STATO_0000291> "http://mathworld.wolfram.com/Quantile.html"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/STATO_0000291> "quantile"@en)
