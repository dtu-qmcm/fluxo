AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> <http://purl.obolibrary.org/obo/RO_0002431> "involved in or reguates")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/RO_0002431> "involved in or involved in regulation of")
