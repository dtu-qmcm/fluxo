AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/APOLLO_SV_00000796> "William R. Hogan"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> <http://purl.obolibrary.org/obo/APOLLO_SV_00000796> "data set creation"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> <http://purl.obolibrary.org/obo/APOLLO_SV_00000796> "dataset creation"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/APOLLO_SV_00000796> "dataset creating"@en)
