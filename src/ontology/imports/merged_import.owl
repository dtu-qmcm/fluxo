AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/STATO_0000113> "Philippe Rocca-Serra"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000118> <http://purl.obolibrary.org/obo/STATO_0000113> "σ2"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/STATO_0000113> "variance"@en)
