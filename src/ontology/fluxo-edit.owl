# Class: obo:FLUXO_0000018 (stoichiometry-based fluxomics method)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000018 "The metabolic flux anlaysis method based on mathemetical approaches for characterizing metabolic states that constrain the possible flux space given a reaction stoichiometry.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000018 "Sergi: Move to planned process")
AnnotationAssertion(rdfs:label obo:FLUXO_0000018 "stoichiometry-based fluxomics method")
SubClassOf(obo:FLUXO_0000018 obo:FLUXO_0000021)

# Class: obo:FLUXO_0000019 (constraint-based fluxomics method)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000019 "The stoichiometry-based fluxomics method that uses set of mathematical approaches in which the possible fluxes are constrained by a minimum and maximum range of bounds, and further restrictions such as the reaction stoichiometry or objectives.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000019 "constraint-based fluxomics method")
SubClassOf(obo:FLUXO_0000019 obo:FLUXO_0000018)

# Class: obo:FLUXO_0000020 (flux measurement method)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000020 "A metabolic flux analysis method that determines metabolic fluxes within a cell based on empirical data.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000020 "Sergi: Move to planned process")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000020 "Te: This should be in plan specification based on definition")
AnnotationAssertion(rdfs:label obo:FLUXO_0000020 "flux measurement method")
SubClassOf(obo:FLUXO_0000020 obo:IAO_0000104)

# Class: obo:FLUXO_0000021 (metabolic flux analysis method)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000021 "A plan specification that quantitatively estimate/infer metabolic fluxes using a metabolic reaction model, experimental data and computation.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000021 "metabolic flux analysis method")
SubClassOf(obo:FLUXO_0000021 obo:IAO_0000104)
