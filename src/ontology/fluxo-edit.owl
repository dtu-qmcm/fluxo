AnnotationAssertion(rdfs:label obo:FLUXO_0000167 "reactant")
SubClassOf(obo:FLUXO_0000167 obo:FLUXO_0000172)

# Class: obo:FLUXO_0000168 (substrate)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000168 "A substrate is molecule or pseudo molecule which is on the left side of the reaction equation.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000168 "http://biomodels.net/SBO/SBO_0000015")
AnnotationAssertion(rdfs:label obo:FLUXO_0000168 "substrate")
SubClassOf(obo:FLUXO_0000168 obo:FLUXO_0000167)

# Class: obo:FLUXO_0000169 (product)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000169 "A product is molecule or pseudo molecule which is on the right side of the reaction equation.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000169 "http://biomodels.net/SBO/SBO_0000011")
AnnotationAssertion(rdfs:label obo:FLUXO_0000169 "product")
SubClassOf(obo:FLUXO_0000169 obo:FLUXO_0000172)

# Class: obo:FLUXO_0000170 (molecule)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000170 "A molecule is any polyatomic entity that is an electrically neutral entity consisting of more than one atom.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000170 "http://purl.obolibrary.org/obo/CHEBI_25367")
AnnotationAssertion(rdfs:label obo:FLUXO_0000170 "molecule")
SubClassOf(obo:FLUXO_0000170 obo:BFO_0000040)

# Class: obo:FLUXO_0000171 (molecular entity)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000171 "Molecular entity is any constitutionally or isotopically distinct atom, molecule, ion, ion pair, radical, radical ion, complex, conformer etc., identifiable as a separately distinguishable entity.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000171 "http://purl.obolibrary.org/obo/CHEBI_23367")
AnnotationAssertion(rdfs:label obo:FLUXO_0000171 "molecular entity")
SubClassOf(obo:FLUXO_0000171 obo:BFO_0000040)

# Class: obo:FLUXO_0000172 (metabolite)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000172 "A metabolite is any intermediate or product resulting from metabolism. The term 'metabolite' subsumes the classes commonly known as primary and secondary metabolites.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000172 "http://purl.obolibrary.org/obo/CHEBI_25212")
AnnotationAssertion(rdfs:label obo:FLUXO_0000172 "metabolite")
SubClassOf(obo:FLUXO_0000172 obo:FLUXO_0000170)

# Class: obo:FLUXO_0000173 (stoichiometry matrix)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000173 "Stoichiometry matrix is the mathematical representation of a metabolic network, with rows representing metabolites and columns representing reactions. Each value indicates the stoichiometric coefficients, metabolites that are consumed are negative values and produced are positive values.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000173 "http://purl.obolibrary.org/obo/MSIO_0000079")
AnnotationAssertion(rdfs:label obo:FLUXO_0000173 "stoichiometry matrix")
SubClassOf(obo:FLUXO_0000173 obo:FLUXO_0000217)

# Class: obo:FLUXO_0000174 (isotopologue)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000174 "An isotopologue is a molecular entity that differs only in isotopic composition (number of isotopic substitutions).")
AnnotationAssertion(Annotation(obo:IAO_0000119 "https://goldbook.iupac.org/terms/view/I03351") oboInOwl:hasDbXref obo:FLUXO_0000174 "http://purl.obolibrary.org/obo/MSIO_0000034")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000174 "isotopologues")
AnnotationAssertion(rdfs:label obo:FLUXO_0000174 "isotopologue")
SubClassOf(obo:FLUXO_0000174 obo:FLUXO_0000031)

# Class: obo:FLUXO_0000175 (isotopomer)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000175 "An isotopomer is isomers having the same number of each isotopic atom but differing in their positions. The term is a contraction of 'isotopic isomer'.")
AnnotationAssertion(Annotation(obo:IAO_0000119 "https://goldbook.iupac.org/terms/view/I03352") oboInOwl:hasDbXref obo:FLUXO_0000175 "http://purl.obolibrary.org/obo/MSIO_0000036")
AnnotationAssertion(rdfs:label obo:FLUXO_0000175 "isotopomer")
SubClassOf(obo:FLUXO_0000175 obo:FLUXO_0000031)

# Class: obo:FLUXO_0000176 (isotopic tracer)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000176 "An isotopic tracer is a isotope of the tracer element that is used in fluxomics investigation. (e.g. 13C in a 13C labelled molecular entity).")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000176 "http://purl.obolibrary.org/obo/MSIO_0000031")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000176 "tracer")
AnnotationAssertion(rdfs:label obo:FLUXO_0000176 "isotopic tracer")
SubClassOf(obo:FLUXO_0000176 obo:COB_0000026)

# Class: obo:FLUXO_0000177 (steady state)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000177 "Steady state is having reached equilibrium for the measurement or phenomenon concerned.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000177 "http://purl.obolibrary.org/obo/NCIT_C151966")
AnnotationAssertion(rdfs:label obo:FLUXO_0000177 "steady state")
SubClassOf(obo:FLUXO_0000177 obo:BFO_0000017)

# Class: obo:FLUXO_0000178 (experimental design and studies)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000178 "Experimental design and studies is the design of an experiment intended to test a hypothesis, and describe or explain empirical data obtained under various experimental conditions.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000178 "http://edamontology.org/topic_3678")
AnnotationAssertion(rdfs:label obo:FLUXO_0000178 "experimental design and studies")
SubClassOf(obo:FLUXO_0000178 obo:COB_0000082)

# Class: obo:FLUXO_0000179 (isotopically steady state labeling experiment)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000179 "An isotopically steady state labeling experiment is an experiment in which isotopically labelled compounds are supplied to a biological system until the ratio of marked to unmarked molecules stabilizes at a constant level.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000179 "http://purl.obolibrary.org/obo/MSIO_0000185")
AnnotationAssertion(rdfs:label obo:FLUXO_0000179 "isotopically steady state labeling experiment")
SubClassOf(obo:FLUXO_0000179 obo:FLUXO_0000049)

# Class: obo:FLUXO_0000180 (isotopically non-stationary labeling experiment)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000180 "An isotopically non-stationary labeling experiment is an experiment measures the rate at which isotopically labelled compounds are incorporated into cellular metabolites over time, specifically before the system reaches a stable isotopic equilibrium.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000180 "http://purl.obolibrary.org/obo/MSIO_0000053")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000180 "isotopically instationary labeling experiment")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000180 "isotopically unstationary labeling experiment")
AnnotationAssertion(rdfs:label obo:FLUXO_0000180 "isotopically non-stationary labeling experiment")
SubClassOf(obo:FLUXO_0000180 obo:FLUXO_0000049)

