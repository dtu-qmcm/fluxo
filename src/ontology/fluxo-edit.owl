Annotation(dc:description "Metabolic Flux Analysis Ontology is an ontology that provides a structured framework for representing concepts, relationships, and data related to metabolic flux analysis.")
Annotation(dc:title "Metabolic Flux Analysis Ontology")
Annotation(terms:license <http://creativecommons.org/licenses/by/4.0/>)
Annotation(owl:versionInfo "2026-04-08")

