# Class: obo:FLUXO_0000191 (liquid chromatography-mass spectrometry)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000191 "A mass spectrometry method where a sample mixture is first separated by liquid chromatography before being converted into ions which are characterised by their mass-to-charge ratio and relative abundance.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000191 "http://purl.obolibrary.org/obo/CHMO_0000524")
AnnotationAssertion(rdfs:label obo:FLUXO_0000191 "liquid chromatography-mass spectrometry")
