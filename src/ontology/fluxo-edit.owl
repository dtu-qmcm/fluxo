# Class: obo:FLUXO_0000201 (demand reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000201 "A pseudo metabolic reaction that represents the reaction operating upon the internal metabolites.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000201 "http://biomodels.net/SBO/SBO_0000628")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000201 "Metabolites that are consumed by these reactions are assumed to be used in intra-cellular processes that are not part of the model. Demand reactions, often represented 'R_DM_', can also deliver metabolites (from intra-cellular processes that are not considered in the model).")
AnnotationAssertion(rdfs:label obo:FLUXO_0000201 "demand reaction")
SubClassOf(obo:FLUXO_0000201 obo:FLUXO_0000065)

# Class: obo:FLUXO_0000202 (exchange reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000202 "A pseudo metabolic reaction that provides influx or efflux across a model boundary, for example replenishes a metabolic network with raw materials (eg carbon / energy sources).")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000202 "http://biomodels.net/SBO/SBO_0000627")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000202 "Such reactions are conceptual, created solely for modeling purposes, and do not have a physical correspondence. Exchange reactions, often represented as 'R_EX_', can operate in the negative (uptake) direction or positive (secretion) direction. By convention, a negative flux through an exchange reaction represents uptake of the corresponding metabolite, and a positive flux represent discharge.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000202 "exchange reaction")
SubClassOf(obo:FLUXO_0000202 obo:FLUXO_0000065)

# Class: obo:FLUXO_0000203 (sink reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000203 "A pseudo metabolic reaction that is an unbalanced, typically reversible reaction used to add or remove intracellular metabolites from the system.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000203 "Te: part of pseudo reaction
All: 
A pseudo metabolic reaction that is unbalanced and is used to add or remove intracellular metabolites from the system.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000203 "http://biomodels.net/SBO/SBO_0000632")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000203 "It is typically a reversible reaction.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000203 "sink reaction")
SubClassOf(obo:FLUXO_0000203 obo:FLUXO_0000065)

# Class: obo:FLUXO_0000204 (reaction stoichiometry)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000204 "An information content entity that represents the relation between the quantities of substances that take part in a reaction or form a compound (typically a ratio of whole integers).")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000204 "Te: ADD: The relation between the quantities of substances that take part in a reaction or form a compound (typically a ratio of whole integers).
Sergi: Not sure this is a data item according to definition")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000204 "http://purl.obolibrary.org/obo/NCIT_C18110")
AnnotationAssertion(rdfs:label obo:FLUXO_0000204 "reaction stoichiometry")
SubClassOf(obo:FLUXO_0000204 obo:IAO_0000030)

