# Class: obo:FLUXO_0000104 (tcaCALC & SIM)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000104 "A metabolic flux analysis software that is a MATLAB-based software for estimating TCA cycle fluxes from 13C NMR isotopomer data (Chance et al., J Biol Chem, 1983; Malloy et al., Am J Physiol, 1990).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000104 "SIM performs forward simulation of isotopic labeling in the citric acid cycle; tcaCALC performs flux calculation by fitting simulated isotopomer patterns to observed NMR data.")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000104 "https://invivometabolism.org/tca.html")
AnnotationAssertion(rdfs:label obo:FLUXO_0000104 "tcaCALC & SIM")
SubClassOf(obo:FLUXO_0000104 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000105 (13CFLUX)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000105 "A metabolic flux analysis software that is a universal software framework for 13C-based metabolic flux analysis that supports modeling, simulation, design, evaluation, and statistical analysis of 13C-labeling experiments using a cumomer-based simulation approach (Wiechert et al., Metab Eng, 2001, DOI: 10.1006/mben.2001.0188).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000105 "https://www.13cflux.net/13cflux/index.html")
AnnotationAssertion(rdfs:label obo:FLUXO_0000105 "13CFLUX")
SubClassOf(obo:FLUXO_0000105 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000106 (13CFLUXv3)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000106 "A metabolic flux analysis software that is a third-generation, high-performance simulator supporting both isotopically stationary and non-stationary 13C-MFA, featuring dual EMU/cumomer representations, multi-isotope tracer support, Bayesian uncertainty quantification, and a Python API (Stratmann et al., Bioinformatics, 2025, DOI: 10.1093/bioinformatics/btaf630).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000106 "https://x3cflux.readthedocs.io/en/latest/")
AnnotationAssertion(rdfs:label obo:FLUXO_0000106 "13CFLUXv3")
SubClassOf(obo:FLUXO_0000106 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000107 (influx_s)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000107 "A metabolic flux analysis software that for estimating metabolic fluxes from stationary isotopic labeling data using the NLSIC algorithm, which provides more reliable convergence and better numerical accuracy than other optimization methods (Sokol et al., Bioinformatics, 2012, DOI: 10.1093/bioinformatics/bts705).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000107 "https://influx-si.readthedocs.io/en/latest/intro.html#influx-s")
AnnotationAssertion(rdfs:label obo:FLUXO_0000107 "influx_s")
SubClassOf(obo:FLUXO_0000107 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000108 (influx_si)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000108 "A metabolic flux analysis software that is an extended version of influx_s that handles isotopically non-stationary labeling experiments, sharing the same NLSIC fitting algorithm and input/output formats with unconditional stability during ODE solving (Sokol et al., Bioinformatics, 2012, DOI: 10.1093/bioinformatics/bts705).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000108 "https://influx-si.readthedocs.io/en/latest/index.html")
AnnotationAssertion(rdfs:label obo:FLUXO_0000108 "influx_si")
SubClassOf(obo:FLUXO_0000108 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000109 (INCA2)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000109 "A metabolic flux analysis software that is an updated MATLAB-based 13C MFA software building on the INCA platform, supporting both steady-state and isotopically non-stationary MFA with the EMU framework, parallel labeling experiments, and improved computational capabilities (Young, Bioinformatics, 2014, DOI: 10.1093/bioinformatics/btu015).")
AnnotationAssertion(rdfs:label obo:FLUXO_0000109 "INCA2")
SubClassOf(obo:FLUXO_0000109 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000110 (Open Mebius)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000110 "A metabolic flux analysis software that is an open-source MATLAB-based software for both conventional and isotopically nonstationary 13C-MFA, featuring auto-generation of metabolic models from Excel configuration worksheets and using the Levenberg-Marquardt method for flux estimation (Kajihata et al., BioMed Res Int, 2014, DOI: 10.1155/2014/627014).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000110 "https://en.metabolic-engineering.jp/page/software/openmebius")
AnnotationAssertion(rdfs:label obo:FLUXO_0000110 "Open Mebius")
SubClassOf(obo:FLUXO_0000110 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000111 (mfapy)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000111 "A metabolic flux analysis software that is an open-source Python package for 13C-MFA supporting the EMU framework, INST-MFA, parallel labeling experiments, and a Bayesian Metropolis-Hastings approach, providing flexibility for custom analysis workflows and experimental design via simulation (Matsuda et al., Metab Eng Commun, 2021, DOI: 10.1016/j.mec.2021.e00177).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000111 "https://github.com/fumiomatsuda/mfapy")
AnnotationAssertion(rdfs:label obo:FLUXO_0000111 "mfapy")
SubClassOf(obo:FLUXO_0000111 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000112 (OpenFLUX2)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000112 "A metabolic flux analysis software that is an extended version of OpenFLUX with support for parallel labeling experiments, extended statistical analysis, structural identifiability analysis, Monte Carlo confidence interval estimation, and experimental design optimization (Shupletsov et al., Microb Cell Fact, 2014, DOI: 10.1186/s12934-014-0152-x).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000112 "https://sourceforge.net/projects/openflux2/")
AnnotationAssertion(rdfs:label obo:FLUXO_0000112 "OpenFLUX2")
SubClassOf(obo:FLUXO_0000112 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000113 (sysmetab)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000113 "A metabolic flux analysis software that is a Scilab-based open-source software for 13C metabolic flux analysis that provides tools for isotopomer modeling and flux estimation.")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000113 "https://gitlab.com/scilab/forge/sysmetab/")
AnnotationAssertion(rdfs:label obo:FLUXO_0000113 "sysmetab")
SubClassOf(obo:FLUXO_0000113 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000114 (WUFlux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000114 "A metabolic flux analysis software that is a MATLAB-based 13C MFA software with graphical user interface that supports steady-state 13C-MFA with user-friendly data input and flux visualization (He et al., Biotechnol Bioeng, 2016, DOI: 10.1002/bit.25958).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000114 "https://tang.eece.wustl.edu/ToolDevelopment.html")
AnnotationAssertion(rdfs:label obo:FLUXO_0000114 "WUFlux")
SubClassOf(obo:FLUXO_0000114 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000115 (FluxPyt)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000115 "A metabolic flux analysis software that is a Python-based software package for stationary 13C metabolic flux analysis to estimate intracellular flux distributions.")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000115 "https://sourceforge.net/projects/fluxpyt")
AnnotationAssertion(rdfs:label obo:FLUXO_0000115 "FluxPyt")
SubClassOf(obo:FLUXO_0000115 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000116 (EMUlator)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000116 "A metabolic flux analysis software that is an EMU-based isotope simulator that uses adjacency matrix representation to efficiently simulate isotopic labeling patterns, enabling rapid forward simulation of mass isotopomer distributions for metabolic flux analysis and experimental design (Wu et al., Front Microbiol, 2019, DOI: 10.3389/fmicb.2019.00922).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000116 "https://doi.org/10.3389/fmicb.2019.00922")
AnnotationAssertion(rdfs:label obo:FLUXO_0000116 "EMUlator")
SubClassOf(obo:FLUXO_0000116 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000117 (freeflux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000117 "A metabolic flux analysis software that is a Python package for 13C metabolic flux analysis at both isotopic steady state and transient state, supporting flux estimation, labeling pattern simulation, flux balance/variability analysis, and 15N labeling data (Wu et al., ACS Synth Biol, 2023, DOI: 10.1021/acssynbio.3c00265).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000117 "https://github.com/Chaowu88/freeflux")
AnnotationAssertion(rdfs:label obo:FLUXO_0000117 "freeflux")
SubClassOf(obo:FLUXO_0000117 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000118 (eiFlux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000118 "A metabolic flux analysis software that is a MATLAB-based software that formulates isotope-assisted MFA as an equality-constrained nonlinear program, improving scalability and robustness compared to traditional formulations (Lugar and Sriram, PLOS Comput Biol, 2022, DOI: 10.1371/journal.pcbi.1009831).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000118 "https://doi.org/10.1371/journal.pcbi.1009831")
AnnotationAssertion(rdfs:label obo:FLUXO_0000118 "eiFlux")
SubClassOf(obo:FLUXO_0000118 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000119 (CeCaFlux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000119 "A metabolic flux analysis software that is a web-based server for INST-13C MFA with standardized and visual flux analysis, using evolutionary optimization in parallel and providing real-time visualization of the flux optimization process (Liu et al., Bioinformatics, 2022, DOI: 10.1093/bioinformatics/btac341).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000119 "https://github.com/zhzhd82/CeCaFLUX")
AnnotationAssertion(rdfs:label obo:FLUXO_0000119 "CeCaFlux")
SubClassOf(obo:FLUXO_0000119 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000120 (BayFlux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000120 "A metabolic flux analysis software that is an open-source software library for Bayesian genome-scale 13C metabolic flux analysis, using MCMC Bayesian inference with COBRApy for handling genome-scale models and supporting Two Scale 13C MFA (Backman et al., PLOS Comput Biol, 2023, DOI: 10.1371/journal.pcbi.1011111).")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000120 "https://github.com/JBEI/bayflux")
AnnotationAssertion(rdfs:label obo:FLUXO_0000120 "BayFlux")
SubClassOf(obo:FLUXO_0000120 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000121 (Freeflux specification)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000121 "A data format specification for defining metabolic models and experimental data used by the FreeFlux software package.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000121 "Freeflux specification")
SubClassOf(obo:FLUXO_0000121 obo:IAO_0000098)

# Class: obo:FLUXO_0000122 (INCA specification)

