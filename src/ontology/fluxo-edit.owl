AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000207 "http://purl.obolibrary.org/obo/STATO_0000039")
AnnotationAssertion(rdfs:label obo:FLUXO_0000207 "statistic")
SubClassOf(obo:FLUXO_0000207 obo:IAO_0000027)

# Class: obo:FLUXO_0000208 (standard deviation)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000208 "A statistic that is a measure of variation which correspond to the average distance from the mean of the data set to any given point of that dataset. It also corresponds to the square root of its variance.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000208 "http://purl.obolibrary.org/obo/STATO_0000237")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000208 "It can be for a random variable, statistical population, data set, or probability distribution.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000208 "standard deviation")
SubClassOf(obo:FLUXO_0000208 obo:FLUXO_0000207)

# Class: obo:FLUXO_0000209 (confidence interval)

