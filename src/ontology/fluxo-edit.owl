# Class: obo:FLUXO_0000243 (version number)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000243 "A version number is an information content entity which is a sequence of characters borne by part of each of a class of manufactured products or its packaging and indicates its order within a set of other products having the same name. [IAO]")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000243 "http://purl.obolibrary.org/obo/IAO_0000129")
AnnotationAssertion(rdfs:label obo:FLUXO_0000243 "version number")
SubClassOf(obo:FLUXO_0000243 obo:FLUXO_0000242)

# Class: obo:FLUXO_0000244 (13CFLUX2)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000244 "13CFLUX2 is a high-performance software suite for steady-state 13C-MFA featuring efficient cumomer and EMU simulation algorithms, arbitrary measurement specifications, FluxML standardized file format, and bindings for optimization frameworks like IPOPT (Weitzel et al., Bioinformatics, 2013, DOI: 10.1093/bioinformatics/bts646).")
AnnotationAssertion(Annotation(obo:IAO_0000119 "https://doi.org/10.1093/bioinformatics/bts646") oboInOwl:hasDbXref obo:FLUXO_0000244 "http://purl.obolibrary.org/obo/MSIO_0000042")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000244 "https://www.13cflux.net/13cflux2/index.html")
AnnotationAssertion(rdfs:label obo:FLUXO_0000244 "13CFLUX2")
SubClassOf(obo:FLUXO_0000244 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000245 (FiatFlux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000245 "FiatFlux is a user-friendly software package for 13C metabolic flux analysis that automatically calculates flux ratios from GC-MS-detected 13C patterns in protein-bound amino acids, and then estimates net fluxes from extracellular flux measurements and the determined ratios (Zamboni et al., BMC Bioinformatics, 2005, DOI: 10.1186/1471-2105-6-209).")
AnnotationAssertion(Annotation(obo:IAO_0000119 "https://doi.org/10.1186/1471-2105-6-209") oboInOwl:hasDbXref obo:FLUXO_0000245 "http://purl.obolibrary.org/obo/MSIO_0000044")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000245 "https://imsb.ethz.ch/research/zamboni/resources/fiatflux.html")
AnnotationAssertion(rdfs:label obo:FLUXO_0000245 "FiatFlux")
SubClassOf(obo:FLUXO_0000245 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000246 (SUMOFLUX)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000246 "SUMOFLUX is a MATLAB-based toolbox for targeted 13C metabolic flux ratio analysis using surrogate modeling, generating random metabolic flux distributions and 13C labeling patterns, then training machine learning models to predict specific flux ratios from measured labeling data (Kogadeeva and Zamboni, PLOS Comput Biol, 2016, DOI: 10.1371/journal.pcbi.1005109).")
AnnotationAssertion(Annotation(obo:IAO_0000119 "https://doi.org/10.1371/journal.pcbi.1005109") oboInOwl:hasDbXref obo:FLUXO_0000246 "http://purl.obolibrary.org/obo/MSIO_0000057")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000246 "https://github.com/zamboni-lab/sumoflux")
AnnotationAssertion(rdfs:label obo:FLUXO_0000246 "SUMOFLUX")
SubClassOf(obo:FLUXO_0000246 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000247 (metran)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000247 "METRAN is a MATLAB-based 13C-MFA software based on the Elementary Metabolite Unit (EMU) framework, supporting steady-state MFA, tracer experiment design, and statistical analysis (Antoniewicz et al., Metab Eng, 2007, DOI: 10.1016/j.ymben.2006.09.001).")
AnnotationAssertion(Annotation(obo:IAO_0000119 "https://doi.org/10.1074/jbc.M706494200") oboInOwl:hasDbXref obo:FLUXO_0000247 "http://purl.obolibrary.org/obo/MSIO_0000051")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000247 "https://tlo.mit.edu/industry-entrepreneurs/available-technologies/metran-software-13c-metabolic-flux-analysis")
AnnotationAssertion(rdfs:label obo:FLUXO_0000247 "metran")
SubClassOf(obo:FLUXO_0000247 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000248 (OpenFLUX)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000248 "OpenFLUX is an open-source MATLAB/Java-based modelling software for 13C metabolic flux analysis implementing the EMU technique, featuring a Java GUI for model generation and MATLAB-based flux analysis (Quek et al., Microb Cell Fact, 2009, DOI: 10.1186/1475-2859-8-25).")
AnnotationAssertion(Annotation(obo:IAO_0000119 "https://doi.org/10.1186/1475-2859-8-25") oboInOwl:hasDbXref obo:FLUXO_0000248 "http://purl.obolibrary.org/obo/MSIO_0000035")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000248 "https://openflux.sourceforge.net/")
AnnotationAssertion(rdfs:label obo:FLUXO_0000248 "OpenFLUX")
SubClassOf(obo:FLUXO_0000248 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000249 (INCA)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000249 "INCA is a MATLAB-based computational platform that was the first publicly available software to perform both steady-state and isotopically non-stationary 13C-MFA, using the EMU framework and supporting parallel labeling experiments, goodness-of-fit testing, and confidence interval estimation (Young, Bioinformatics, 2014, DOI: 10.1093/bioinformatics/btu015).")
AnnotationAssertion(Annotation(obo:IAO_0000119 "https://doi.org/10.1093/bioinformatics/btu015") oboInOwl:hasDbXref obo:FLUXO_0000249 "http://purl.obolibrary.org/obo/MSIO_0000047")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000249 "Isotopomer Network Compartmental Analysis")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000249 "https://mfa.vueinnovations.com/")
AnnotationAssertion(rdfs:label obo:FLUXO_0000249 "INCA")
SubClassOf(obo:FLUXO_0000249 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000250 (iso2flux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000250 "Iso2Flux is a Python-based flux analysis software that allows to perform 13C Metabolic Flux Analysis on a sub-network of a large scale model. Iso2flux uses constraint-based modelling to compute steady state fluxes across a large metabolic network and uses such flxues to predict 13C distribution across a subser of the newtork. Then, given a set of 13C data Iso2flux can iteratively find the steady state flux distributions that are most consistent with such fluxes.  the source code is available from: https://github.com/cfoguet/iso2flux")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000250 "http://purl.obolibrary.org/obo/MSIO_0000048")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000250 "https://github.com/phnmnl/container-iso2flux")
AnnotationAssertion(rdfs:label obo:FLUXO_0000250 "iso2flux")
SubClassOf(obo:FLUXO_0000250 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000251 (isodyn)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000251 "“Isodyn” is a C++-program that performs an analysis of stable isotope tracer data to assess metabolic flux profiles in living cells. Isodyn simulates the dynamics of isotopic isomer (isotopomer) distribution in central metabolic pathways, and, by changing its parameters, which reflect the characteristics of corresponding biochemical reactions, fit the simulated dynamics of mass isotopomers to that observed experimentally. The simulated metabolic fluxes that correspond to the best fit are assumed to reproduce the real fluxes in the analyzed biological object and conditions. Isodyn contains tools that check the goodness of fit and perform a statistical analysis of obtained metabolic fluxes.  the source code is available from: https://github.com/seliv55/isodyn.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000251 "http://purl.obolibrary.org/obo/MSIO_0000049")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000251 "https://bio.tools/Isodyn")
AnnotationAssertion(rdfs:label obo:FLUXO_0000251 "isodyn")
SubClassOf(obo:FLUXO_0000251 obo:FLUXO_0000103)

# Class: obo:FLUXO_0000252 (IsoDesign)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000252 "IsoDesign, a software that enables these parameters to be maximized by optimizing the isotopic composition of the label input. It can be applied to (13) C-MFA investigations using a broad panel of analytical tools (MS, MS/MS, (1) H NMR, (13) C NMR, etc.) individually or in combination. It includes a visualization module to intuitively select the optimal label input depending on the biological question to be addressed.  The software is available from: http://metasys.insa-toulouse.fr/software/isodes/.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000252 "http://purl.obolibrary.org/obo/MSIO_0000050")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000252 "https://isodesign.readthedocs.io/en/latest/")
AnnotationAssertion(rdfs:label obo:FLUXO_0000252 "IsoDesign")
SubClassOf(obo:FLUXO_0000252 obo:FLUXO_0000103)

