AnnotationAssertion(rdfs:label obo:FLUXO_0000095 "D-parameter")
SubClassOf(obo:FLUXO_0000095 obo:FLUXO_0000094)

# Class: obo:FLUXO_0000096 (G-parameter)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000096 "A nuisance parameter that is to account for residual naturally labeled fractions in a measurement group.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000096 "G-parameter")
SubClassOf(obo:FLUXO_0000096 obo:FLUXO_0000094)

# Class: obo:FLUXO_0000097 (experimental design criterion)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000097 "A mathematical expression that represents a criterion value for a proposed experimental design.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000097 "experimental design criterion")
SubClassOf(obo:FLUXO_0000097 obo:FLUXO_0000223)

# Class: obo:FLUXO_0000098 (FML format)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000098 "An XML format that is defined by FluxML specification for modeling metabolic flux analysis.")
