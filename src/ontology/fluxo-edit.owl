AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000213 "A statistical hypothesis test that the sampling distribution of the test statistic is a chi-square distribution when the null hypothesis is true, or any in which this is asymptotically true.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000213 "http://purl.obolibrary.org/obo/OBI_0200200")
AnnotationAssertion(rdfs:label obo:FLUXO_0000213 "chi-square test")
SubClassOf(obo:FLUXO_0000213 obo:FLUXO_0000211)

