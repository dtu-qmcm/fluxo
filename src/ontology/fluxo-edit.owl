AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000209 "http://purl.obolibrary.org/obo/STATO_0000196")
AnnotationAssertion(rdfs:label obo:FLUXO_0000209 "confidence interval")
SubClassOf(obo:FLUXO_0000209 obo:FLUXO_0000207)

