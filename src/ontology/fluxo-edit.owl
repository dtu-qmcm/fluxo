AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000212 "a goodness of fit statistical test is a statistical test which aim to evaluate if a sample distribution can be considered equivalent to a theoretical distribution used as input")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000212 "http://purl.obolibrary.org/obo/STATO_0000191")
AnnotationAssertion(rdfs:label obo:FLUXO_0000212 "goodness of fit statistical test")
