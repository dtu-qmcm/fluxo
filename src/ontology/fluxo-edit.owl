AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000205 "http://purl.obolibrary.org/obo/MSIO_0000060")
AnnotationAssertion(rdfs:label obo:FLUXO_0000205 "stoichiometric coefficient")
SubClassOf(obo:FLUXO_0000205 obo:IAO_0000030)

# Class: obo:FLUXO_0000206 (flux bound)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000206 "A flux inequality constraint that limits the upper or lower value that a flux may assume.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000206 "http://biomodels.net/SBO/SBO_0000625")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000206 "This parameter may be determined experimentally, or may be the result of theoretical investigation.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000206 "flux bound")
SubClassOf(obo:FLUXO_0000206 obo:FLUXO_0000153)

# Class: obo:FLUXO_0000207 (statistic)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000207 "A data item to describe a dataset or a variable, and it is generated by a calculation on set of observed data.")
