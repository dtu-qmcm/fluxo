SubClassOf(obo:FLUXO_0000082 obo:FLUXO_0000210)

# Class: obo:FLUXO_0000083 (growth rate)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000083 "A measurement datum that measures the rate of biomass formation.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000083 "Te: Isn't this a quality? refer to PATO:0001492
Sergi: I don't think so, it's a number measuring how fast cells are growing. A quality does not require any process to be realized according to definition, and growth rate depends on a lot of factors and other stuff. If this was max growth rate, ir would be a realizable entity.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000083 "http://purl.obolibrary.org/obo/PATO_0001492")
AnnotationAssertion(rdfs:label obo:FLUXO_0000083 "growth rate")
SubClassOf(obo:FLUXO_0000083 obo:IAO_0000109)

# Class: obo:FLUXO_0000084 (specific growth rate)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000084 "A growth rate that measures the biomass increase per unit of existing biomass per unit of time.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000084 "specific growth rate")
SubClassOf(obo:FLUXO_0000084 obo:FLUXO_0000083)

# Class: obo:FLUXO_0000085 (yield)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000085 "A measurement datum that represents the efficiency of substrate conversion into product/biomass (mass or molar basis).")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000085 "Te: what about SSSOM with SBO:0000668")
AnnotationAssertion(rdfs:label obo:FLUXO_0000085 "yield")
SubClassOf(obo:FLUXO_0000085 obo:IAO_0000109)

# Class: obo:FLUXO_0000086 (weighted sum of squared residuals)

AnnotationAssertion(obo:IAO_0000112 obo:FLUXO_0000086 "It is used in flux estimation, specifically the variance-weighted sum of squares residuals, which is minimized to quantify fluxes. It serves as a key indicator of goodness-of-fit to reflect the certainty with which metabolic fluxes were determined.")
AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000086 "A statistic that measures the gap between observed values and model predictions, and unlike ordinary least squares, it assigns a specific weight to each data point.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000086 "weighted sum of squared residuals")
SubClassOf(obo:FLUXO_0000086 obo:FLUXO_0000207)

# Class: obo:FLUXO_0000087 (labeling simulation)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000087 "A data transformation that used to obtain labeling data from a given metabolic models and presumed fluxes/metabolite concentrations.")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000087 "forward simulation")
AnnotationAssertion(rdfs:label obo:FLUXO_0000087 "labeling simulation")
SubClassOf(obo:FLUXO_0000087 obo:OBI_0200000)

# Class: obo:FLUXO_0000088 (metabolic flux estimation)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000088 "A model parameter estimation that quantifies metabolic fluxes including their uncertainties.")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000088 "metabolic flux fitting")
AnnotationAssertion(rdfs:label obo:FLUXO_0000088 "metabolic flux estimation")
SubClassOf(obo:FLUXO_0000088 obo:FLUXO_0000057)

# Class: obo:FLUXO_0000089 (labeling measurement model)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000089 "A statistical mdoel that is to describe how to compute a labeling measurement based on the simulated labeling state space.")
AnnotationAssertion(oboInOwl:hasBroadSynonym obo:FLUXO_0000089 "measurement model")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000089 "It is usually represented as a matrix.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000089 "labeling measurement model")
SubClassOf(obo:FLUXO_0000089 obo:FLUXO_0000216)

# Class: obo:FLUXO_0000090 (simulated isotopic measurement)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000090 "A measurement value of a measured quantity as obtained by a forward simulation of the metabolic network model.")
AnnotationAssertion(oboInOwl:hasBroadSynonym obo:FLUXO_0000090 "simulated measurement")
AnnotationAssertion(rdfs:label obo:FLUXO_0000090 "simulated isotopic measurement")
SubClassOf(obo:FLUXO_0000090 obo:IAO_0000027)

# Class: obo:FLUXO_0000091 (error model)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000091 "A statistical model that is to calculate the measurement standard deviation of a simulated measurement.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000091 "error model")
SubClassOf(obo:FLUXO_0000091 obo:FLUXO_0000216)

# Class: obo:FLUXO_0000092 (correction matrix)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000092 "A matrix that is used to remove the contribution of naturally occurring heavy isotopes (e.g., 13C, 15N, 18O) from raw mass spectrometry data.")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000092 "Deconvolution matrix")
AnnotationAssertion(rdfs:label obo:FLUXO_0000092 "correction matrix")
SubClassOf(obo:FLUXO_0000092 obo:FLUXO_0000217)

# Class: obo:FLUXO_0000093 (lumped measurements)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000093 "Lumped measurements are the measurements corresponding to the linear combination of two or more metabolites.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000093 "Sergi: Should be moved. Maybe inside measurement datum?")
