AnnotationAssertion(rdfs:label obo:FLUXO_0000194 "isotope ratio mass spectrometry")
SubClassOf(obo:FLUXO_0000194 obo:FLUXO_0000190)

# Class: obo:FLUXO_0000195 (nuclear magnetic resonance spectroscopy)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000195 "A plan specification that is a method to measure the energy states of spin-active nuclei placed in a static magnetic field are interrogated by inducing transitions between the states via radio frequency irradiation.")
