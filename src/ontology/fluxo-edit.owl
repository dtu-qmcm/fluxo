AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000022 "flux space")
AnnotationAssertion(rdfs:label obo:FLUXO_0000022 "steady state flux solution space")
SubClassOf(obo:FLUXO_0000022 obo:IAO_0000030)

# Class: obo:FLUXO_0000023 (flux vector)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000023 "The data item with a list of the rates of all chemical reactions in a biological network.")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000023 "flux distribution")
AnnotationAssertion(rdfs:label obo:FLUXO_0000023 "flux vector")
SubClassOf(obo:FLUXO_0000023 obo:IAO_0000027)

# Class: obo:FLUXO_0000024 (stoichiometric reaction model)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000024 "A representation of chemical or biological networks that uses the quantitative relationships (stoichiometry) between reactants and products.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000024 "Te: it doesn't have to be a biological entity (chemical or biochemical both works), should be moved further up.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000024 "stoichiometric reaction model")
SubClassOf(obo:FLUXO_0000024 obo:FLUXO_0000226)

# Class: obo:FLUXO_0000025 (forward flux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000025 "The reaction rate at which a specific chemical reaction proceeds from reactants to products.")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000025 "non-negative")
AnnotationAssertion(rdfs:label obo:FLUXO_0000025 "forward flux")
SubClassOf(obo:FLUXO_0000025 obo:FLUXO_0000236)

# Class: obo:FLUXO_0000026 (backward flux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000026 "The reaction rate at which a specific reaction proceeds from products to reactants.")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000026 "reverse flux")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000026 "non-negative")
AnnotationAssertion(rdfs:label obo:FLUXO_0000026 "backward flux")
SubClassOf(obo:FLUXO_0000026 obo:FLUXO_0000236)

# Class: obo:FLUXO_0000027 (net flux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000027 "The reaction rate that denotes the difference between the forward and backward flux for a chemical reaction.")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000027 "net rate")
AnnotationAssertion(rdfs:label obo:FLUXO_0000027 "net flux")
SubClassOf(obo:FLUXO_0000027 obo:FLUXO_0000236)

# Class: obo:FLUXO_0000028 (exchange flux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000028 "The reaction rate that denotes the minimum of the forward and backward fluxes of a chemical reaction.")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000028 "non-negative; This is different from exchange flux in flux balance analysis (make note in ontology)")
AnnotationAssertion(rdfs:label obo:FLUXO_0000028 "exchange flux")
SubClassOf(obo:FLUXO_0000028 obo:FLUXO_0000236)

# Class: obo:FLUXO_0000029 (flux ratio)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000029 "The data item that represents the relative proportion of metabolic flow directed into a specific pathway at a divergence point compared to the total flow or an alternative route at that same junction.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000029 "flux ratio")
SubClassOf(obo:FLUXO_0000029 obo:IAO_0000027)

# Class: obo:FLUXO_0000030 (degrees of freedom in stoichiometry matrix)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000030 "A data item represents the number of free/independent fluxes that can be varied independently within the network, which is determined by the null space of the stoichiometric matrix.")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000030 "The dimension of this null space gives the number of fluxes needed to define all other fluxes.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000030 "degrees of freedom in stoichiometry matrix")
SubClassOf(obo:FLUXO_0000030 obo:IAO_0000027)

