# Class: obo:FLUXO_0000190 (mass spectrometry method)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000190 "A plan specification that is a spectrometry where the sample is converted into gaseous ions which are characterised by their mass-to-charge ratio and relative abundance.")
AnnotationAssertion(oboInOwl:hasBroadSynonym obo:FLUXO_0000190 "mass spectrometry")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000190 "http://purl.obolibrary.org/obo/CHMO_0000470")
