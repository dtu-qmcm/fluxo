AnnotationAssertion(rdfs:label obo:FLUXO_0000199 "chemical formula")
SubClassOf(obo:FLUXO_0000199 obo:IAO_0000027)

# Class: obo:FLUXO_0000200 (molecular charge)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000200 "Molecular charge is the net charge of a molecule.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000200 "http://edamontology.org/data_0845")
AnnotationAssertion(rdfs:label obo:FLUXO_0000200 "molecular charge")
SubClassOf(obo:FLUXO_0000200 obo:IAO_0000027)

# Class: obo:FLUXO_0000201 (demand reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000201 "A modeling process analogous to exchange reaction, but which operates upon \"internal\" metabolites. Metabolites that are consumed by these reactions are assumed to be used in intra-cellular processes that are not part of the model. Demand reactions, often represented 'R_DM_', can also deliver metabolites (from intra-cellular processes that are not considered in the model).")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000201 "Te: under pseudo reaction")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000201 "http://biomodels.net/SBO/SBO_0000628")
AnnotationAssertion(rdfs:label obo:FLUXO_0000201 "demand reaction")
SubClassOf(obo:FLUXO_0000201 obo:FLUXO_0000005)

# Class: obo:FLUXO_0000202 (exchange reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000202 "An exchange reaction is a modeling process to provide matter influx or efflux to a model, for example to replenish a metabolic network with raw materials (eg carbon / energy sources). Such reactions are conceptual, created solely for modeling purposes, and do not have a physical correspondence. Exchange reactions, often represented as 'R_EX_', can operate in the negative (uptake) direction or positive (secretion) direction. By convention, a negative flux through an exchange reaction represents uptake of the corresponding metabolite, and a positive flux represent discharge.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000202 "http://biomodels.net/SBO/SBO_0000627")
AnnotationAssertion(rdfs:label obo:FLUXO_0000202 "exchange reaction")
SubClassOf(obo:FLUXO_0000202 obo:FLUXO_0000005)

# Class: obo:FLUXO_0000203 (sink reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000203 "A sink reaction is an unbalanced, typically reversible reaction used to add or remove intracellular metabolites from the system.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000203 "Te: part of pseudo reaction")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000203 "http://biomodels.net/SBO/SBO_0000632")
AnnotationAssertion(rdfs:label obo:FLUXO_0000203 "sink reaction")
SubClassOf(obo:FLUXO_0000203 obo:FLUXO_0000005)

# Class: obo:FLUXO_0000204 (reaction stoichiometry)

AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000204 "Te: ADD: The relation between the quantities of substances that take part in a reaction or form a compound (typically a ratio of whole integers).
Sergi: Not sure this is a data item according to definition")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000204 "http://purl.obolibrary.org/obo/NCIT_C18110")
AnnotationAssertion(rdfs:label obo:FLUXO_0000204 "reaction stoichiometry")
SubClassOf(obo:FLUXO_0000204 obo:IAO_0000027)

# Class: obo:FLUXO_0000205 (stoichiometric coefficient)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000205 "A stoichiometric coefficient is an information object which is part of an equation describing a chemical reaction and which corresponds to the number of molecules of a reactant  taking part in a reaction.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000205 "Sergi: This shouldn't be in data item according to definition")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000205 "http://purl.obolibrary.org/obo/MSIO_0000060")
AnnotationAssertion(rdfs:label obo:FLUXO_0000205 "stoichiometric coefficient")
SubClassOf(obo:FLUXO_0000205 obo:IAO_0000027)

# Class: obo:FLUXO_0000206 (flux bound)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000206 "A flux bound is a parameter that limits the upper or lower value that a flux may assume. This parameter may be determined experimentally, or may be the result of theoretical investigation.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000206 "http://biomodels.net/SBO/SBO_0000625")
AnnotationAssertion(rdfs:label obo:FLUXO_0000206 "flux bound")
SubClassOf(obo:FLUXO_0000206 obo:FLUXO_0000153)

# Class: obo:FLUXO_0000207 (statistic)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000207 "A statistic is a measurement datum to describe a dataset or a variable. It is generated by a calculation on set of observed data.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000207 "Te: number of degrees of freedom STATO:0000069? for calculation of independent fluxes")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000207 "http://purl.obolibrary.org/obo/STATO_0000039")
AnnotationAssertion(rdfs:label obo:FLUXO_0000207 "statistic")
SubClassOf(obo:FLUXO_0000207 obo:IAO_0000027)

# Class: obo:FLUXO_0000208 (standard deviation)

AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000208 "Te: ADD: The standard deviation of a random variable, statistical population, data set, or probability distribution is a measure of variation which correspond to the average distance from the mean of the data set to any given point of that dataset. It also corresponds to the square root of its variance.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000208 "http://purl.obolibrary.org/obo/STATO_0000237")
AnnotationAssertion(rdfs:label obo:FLUXO_0000208 "standard deviation")
SubClassOf(obo:FLUXO_0000208 obo:FLUXO_0000207)

# Class: obo:FLUXO_0000209 (confidence interval)

AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000209 "Te: DISCUSS: the frequency (i.e., the proportion) of possible confidence intervals that contain the true value of their corresponding parameter. In other words, if confidence intervals are constructed using a given confidence level in an infinite number of independent experiments, the proportion of those intervals that contain the true value of the parameter will match the confidence level.
A probability measure of the reliability of an inferential statistical test that has been applied to sample data and which is provided along with the confidence interval for the output statistic.
Sergi: This definition is defining something else.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000209 "http://purl.obolibrary.org/obo/STATO_0000196")
AnnotationAssertion(rdfs:label obo:FLUXO_0000209 "confidence interval")
SubClassOf(obo:FLUXO_0000209 obo:FLUXO_0000207)

