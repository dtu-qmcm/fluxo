############################
#   Object Properties
############################

# Object Property: obo:FLUXO_0000266 (has specified data input)

AnnotationAssertion(rdfs:label obo:FLUXO_0000266 "has specified data input")
InverseObjectProperties(obo:FLUXO_0000266 obo:FLUXO_0000285)
ObjectPropertyDomain(obo:FLUXO_0000266 obo:IAO_0000010)
ObjectPropertyRange(obo:FLUXO_0000266 obo:IAO_0000027)

# Object Property: obo:FLUXO_0000284 (has specified data output)

AnnotationAssertion(rdfs:label obo:FLUXO_0000284 "has specified data output")
InverseObjectProperties(obo:FLUXO_0000284 obo:FLUXO_0000286)
ObjectPropertyDomain(obo:FLUXO_0000284 obo:IAO_0000010)
ObjectPropertyRange(obo:FLUXO_0000284 obo:IAO_0000027)

# Object Property: obo:FLUXO_0000285 (is specified data input of)

AnnotationAssertion(rdfs:label obo:FLUXO_0000285 "is specified data input of")
ObjectPropertyDomain(obo:FLUXO_0000285 obo:IAO_0000027)
ObjectPropertyRange(obo:FLUXO_0000285 obo:IAO_0000010)

# Object Property: obo:FLUXO_0000286 (is specified data output of)

AnnotationAssertion(rdfs:label obo:FLUXO_0000286 "is specified data output of")
ObjectPropertyDomain(obo:FLUXO_0000286 obo:IAO_0000027)
ObjectPropertyRange(obo:FLUXO_0000286 obo:IAO_0000010)



############################
#   Classes
############################

# Class: obo:FLUXO_0000001 (fluxome)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000001 "An information content entity that represents the complete set of metabolic fluxes (reaction rates) in a biological system at a given point in time.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000001 "Sergi: This is a data item")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000001 "Te: Is this the thing that we are measuring or is it a data collection that describes the state of the metabolism")
AnnotationAssertion(oboInOwl:hasBroadSynonym obo:FLUXO_0000001 "fluxomics")
AnnotationAssertion(rdfs:label obo:FLUXO_0000001 "fluxome")
SubClassOf(obo:FLUXO_0000001 obo:IAO_0000030)

# Class: obo:FLUXO_0000002 (fluxomics data)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000002 "An information content entity that contains files to determine the rates of metabolic reactions.")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000002 "It generally includes the model of metabolic networks and experimental data.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000002 "fluxomics data")
SubClassOf(obo:FLUXO_0000002 obo:IAO_0000030)

# Class: obo:FLUXO_0000003 (internal flux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000003 "A metabolic flux of a metabolic reaction that occurs within a metabolic network model.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000003 "internal flux")
SubClassOf(obo:FLUXO_0000003 obo:FLUXO_0000123)
DisjointClasses(obo:FLUXO_0000003 obo:FLUXO_0000124)

# Class: obo:FLUXO_0000004 (transport flux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000004 "A metabolic flux that is the rate of a transport reaction.")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000004 "transport rate")
AnnotationAssertion(rdfs:label obo:FLUXO_0000004 "transport flux")
SubClassOf(obo:FLUXO_0000004 obo:FLUXO_0000123)

# Class: obo:FLUXO_0000005 (metabolic reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000005 "A chemical or physical process within a biological entity that is part of the metabolism.")
AnnotationAssertion(oboInOwl:hasBroadSynonym obo:FLUXO_0000005 "metabolic process")
AnnotationAssertion(rdfs:label obo:FLUXO_0000005 "metabolic reaction")
SubClassOf(obo:FLUXO_0000005 obo:BFO_0000015)
SubClassOf(obo:FLUXO_0000005 ObjectSomeValuesFrom(obo:RO_0003301 obo:FLUXO_0000126))

# Class: obo:FLUXO_0000006 (reaction bidirectionality)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000006 "A quality of a biochemical reaction which may proceed simultaneously in forward and backward direction.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000006 "Te: A quality is a characteristic?")
AnnotationAssertion(rdfs:label obo:FLUXO_0000006 "reaction bidirectionality")
SubClassOf(obo:FLUXO_0000006 obo:BFO_0000019)

# Class: obo:FLUXO_0000007 (reaction reversibility)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000007 "A quality of metabolic reaction to proceed in forward and backward direction.")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000007 "property could be True or False")
AnnotationAssertion(rdfs:label obo:FLUXO_0000007 "reaction reversibility")
SubClassOf(obo:FLUXO_0000007 obo:BFO_0000019)

# Class: obo:FLUXO_0000008 (unidirectional reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000008 "The chemical reaction that solely operates in a single direction, it can be forward or backward direction.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000008 "Te: Put into parent class")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000008 "irreversible reaction")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000008 "property or class")
AnnotationAssertion(rdfs:label obo:FLUXO_0000008 "unidirectional reaction")
SubClassOf(obo:FLUXO_0000008 obo:FLUXO_0000166)
DisjointClasses(obo:FLUXO_0000008 obo:FLUXO_0000009)

# Class: obo:FLUXO_0000009 (bidirectional reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000009 "The chemical reaction that may operate simultaneously in forward and backward direction.")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000009 "reversible reaction")
AnnotationAssertion(rdfs:label obo:FLUXO_0000009 "bidirectional reaction")
SubClassOf(obo:FLUXO_0000009 obo:FLUXO_0000166)

# Class: obo:FLUXO_0000010 (reaction direction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000010 "A quality of the chemical reaction that shows direction of the reaction operates, which is determined by the Gibbs free energy change.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000010 "reaction direction")
SubClassOf(obo:FLUXO_0000010 obo:BFO_0000019)

# Class: obo:FLUXO_0000011 (forward reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000011 "The chemical reaction that proceeds from reactants to products.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000011 "forward reaction")
SubClassOf(obo:FLUXO_0000011 obo:FLUXO_0000166)

# Class: obo:FLUXO_0000012 (backward reaction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000012 "The chemical reaction that proceeds from products to reactants.")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000012 "reverse direction")
AnnotationAssertion(rdfs:label obo:FLUXO_0000012 "backward reaction")
SubClassOf(obo:FLUXO_0000012 obo:FLUXO_0000166)

# Class: obo:FLUXO_0000013 (chemical equilibrium)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000013 "The realizable entity that is realized when the reactants and products of the chemical process are present in concentrations which have no further tendency to change with time, so that there is no observable change in the properties of the system.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000013 "Sergi: This is not a quality. I'ts a realizable entity")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000013 "Te: Definition of this term is not correct (thermodynamics), and what about non-equilibrium state?")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000013 "At equilibrium, the reaction Gibbs energy is zero.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000013 "chemical equilibrium")
SubClassOf(obo:FLUXO_0000013 obo:BFO_0000017)

# Class: obo:FLUXO_0000014 (source metabolite)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000014 "A metabolite which is only consumed, typically the substrate(s).")
AnnotationAssertion(rdfs:label obo:FLUXO_0000014 "source metabolite")
SubClassOf(obo:FLUXO_0000014 obo:FLUXO_0000172)

# Class: obo:FLUXO_0000015 (sink metabolite)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000015 "A metabolite which is only produced, typically the by-product(s).")
AnnotationAssertion(rdfs:label obo:FLUXO_0000015 "sink metabolite")
SubClassOf(obo:FLUXO_0000015 obo:FLUXO_0000172)

# Class: obo:FLUXO_0000016 (flux map)

AnnotationAssertion(obo:IAO_0000112 obo:FLUXO_0000016 "The flux map is typically scaled by flux magnitude and annotated with directionality.")
AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000016 "The system biology representation that is based on quantitative visualization of reactions and metabolic fluxes within a metabolic network.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000016 "flux map")
SubClassOf(obo:FLUXO_0000016 obo:FLUXO_0000198)

# Class: obo:FLUXO_0000017 (fluxotype)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000017 "An information content entity that indicates specific pattern or distribution of metabolic fluxes within a biological system, such as a cell or organism, under defined conditions.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000017 "Te: put under information content entity or quality? Check phenotype or genotype
Sergi: If we refer to the information about the fluxes yes, if we talk about the stuff that is happening inside the cell it should stay here")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000017 "flux state")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:FLUXO_0000017 "metabolic flux phenotype")
AnnotationAssertion(rdfs:label obo:FLUXO_0000017 "fluxotype")
