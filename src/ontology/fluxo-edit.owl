AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000192 "A mass spectrometry method where a sample mixture is first separated by gas chromatography then ionised and characterised according to mass-to-charge ratio and relative abundance.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000192 "http://purl.obolibrary.org/obo/CHMO_0000497")
AnnotationAssertion(rdfs:label obo:FLUXO_0000192 "gas chromatography-mass spectrometry")
SubClassOf(obo:FLUXO_0000192 obo:FLUXO_0000190)

