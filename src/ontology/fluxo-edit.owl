AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000211 "http://purl.obolibrary.org/obo/OBI_0000673")
AnnotationAssertion(rdfs:label obo:FLUXO_0000211 "statistical hypothesis test")
SubClassOf(obo:FLUXO_0000211 obo:OBI_0200000)

# Class: obo:FLUXO_0000212 (goodness of fit statistical test)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000212 "A statistical hypothesis test that aims to evaluate if a sample distribution can be considered equivalent to a theoretical distribution used as input.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000212 "http://purl.obolibrary.org/obo/STATO_0000191")
AnnotationAssertion(rdfs:label obo:FLUXO_0000212 "goodness of fit statistical test")
