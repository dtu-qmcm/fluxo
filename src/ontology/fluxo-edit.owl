AnnotationAssertion(rdfs:label obo:FLUXO_0000128 "transport reaction")
SubClassOf(obo:FLUXO_0000128 obo:FLUXO_0000005)

# Class: obo:FLUXO_0000129 (pseudomolecule)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000129 "An imaginary construct of a molecular entity that exist purely for modeling reasons (e.g. biomass)")
AnnotationAssertion(rdfs:label obo:FLUXO_0000129 "pseudomolecule")
SubClassOf(obo:FLUXO_0000129 obo:IAO_0000030)

# Class: obo:FLUXO_0000130 (relative exchange flux)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000130 "The minimum of the forward and backward fluxes of a metabolic reaction, calculated by convention as a/(1+a), where a is the exchange flux.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000130 "relative exchange flux")
SubClassOf(obo:FLUXO_0000130 obo:FLUXO_0000028)

# Class: obo:FLUXO_0000131 (tracer isotopologue)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000131 "A molecular entity that differs only in isotopic composition by a single element (e.g. 13C-1-glucose and 13C-2-glucose). In MS, this is the output of the natural isotope abundance correction.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000131 "tracer isotopologue")
SubClassOf(obo:FLUXO_0000131 obo:FLUXO_0000174)

# Class: obo:FLUXO_0000132 (tracer element)

