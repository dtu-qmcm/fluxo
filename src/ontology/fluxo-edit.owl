AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000193 "A mass spectrometry method that is involving multiple mass-selection steps, with some form of fragmentation occurring between each stage.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000193 "http://purl.obolibrary.org/obo/CHMO_0000575")
AnnotationAssertion(rdfs:label obo:FLUXO_0000193 "tandem mass spectrometry")
SubClassOf(obo:FLUXO_0000193 obo:FLUXO_0000190)

