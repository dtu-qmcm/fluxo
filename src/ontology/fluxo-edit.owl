SubClassOf(obo:FLUXO_0000098 obo:FLUXO_0000261)

# Class: obo:FLUXO_0000099 (FluxML specification)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000099 "A data format specification for creating, validating, and exchanging metabolic flux analysis models in 13CFlux Software.")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000099 "It is designed with the aim of providing a standard document format for creating, validating and reliable exchanging of arbitrary metabolic models across different simulation tools.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000099 "FluxML specification")
SubClassOf(obo:FLUXO_0000099 obo:IAO_0000098)

# Class: obo:FLUXO_0000100 (FTBL specification)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000100 "A data format specification that is a tabular text-based file format specification for defining metabolic reaction networks and isotopic labeling data used in 13C metabolic flux analysis.")
AnnotationAssertion(rdfs:comment obo:FLUXO_0000100 "The format is obsolete.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000100 "FTBL specification")
SubClassOf(obo:FLUXO_0000100 obo:IAO_0000098)

# Class: obo:FLUXO_0000101 (MTF specification)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000101 "A data format specification for metabolic tracer flux data exchange in metabolic flux analysis for Influx_si software.")
AnnotationAssertion(rdfs:label obo:FLUXO_0000101 "MTF specification")
SubClassOf(obo:FLUXO_0000101 obo:IAO_0000098)

