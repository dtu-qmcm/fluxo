AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000146 "The representation of isotopic state of a metabolite")
AnnotationAssertion(rdfs:label obo:FLUXO_0000146 "Isotopic State-space Representation")
SubClassOf(obo:FLUXO_0000146 obo:IAO_0000030)

