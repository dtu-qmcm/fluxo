AnnotationAssertion(rdfs:label obo:FLUXO_0000183 "isotope labeling experiment representation")
SubClassOf(obo:FLUXO_0000183 obo:IAO_0000030)

# Class: obo:FLUXO_0000184 (culture medium)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000184 "A culture medium is a processed material that provides the needed nourishment for microorganisms or cells grown in vitro.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000184 "http://purl.obolibrary.org/obo/OBI_0000079")
AnnotationAssertion(rdfs:label obo:FLUXO_0000184 "culture medium")
SubClassOf(obo:FLUXO_0000184 obo:COB_0000026)

# Class: obo:FLUXO_0000185 (device)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000185 "A device is a processed material entity which is designed to be capable of a process.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000185 "http://purl.obolibrary.org/obo/COB_0001300")
AnnotationAssertion(rdfs:label obo:FLUXO_0000185 "device")
SubClassOf(obo:FLUXO_0000185 obo:COB_0000026)

# Class: obo:FLUXO_0000186 (mass spectrometer)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000186 "A mass spectrometer is an instrument which is used to measure the mass to charge ratio of ions. All mass spectrometers consist of three basic parts: an ion source, a mass analyzer, and a detector system. The stages within the mass spectrometer are: 1. Production of ions from the sample 2. Separation of ions with different masses 3. Detection of the number of ions of each mass produced 4.Collection of data to generate the mass spectrum")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000186 "Te: Should we include GC-MS and LC-MS (spectrometor)? OR in general OBI:0000048, what is the use case?")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000186 "http://purl.obolibrary.org/obo/OBI_0000049")
AnnotationAssertion(rdfs:label obo:FLUXO_0000186 "mass spectrometer")
SubClassOf(obo:FLUXO_0000186 obo:FLUXO_0000185)

# Class: obo:FLUXO_0000187 (NMR instrument)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000187 "An Instrument which is used to carry out a NMR analysis of some sample.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000187 "http://purl.obolibrary.org/obo/OBI_0000566")
AnnotationAssertion(rdfs:label obo:FLUXO_0000187 "NMR instrument")
SubClassOf(obo:FLUXO_0000187 obo:FLUXO_0000185)

# Class: obo:FLUXO_0000188 (metabolomics)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000188 "Metabolomics is the systematic study of metabolites, the chemical processes they are involved, and the chemical fingerprints of specific cellular processes in a whole cell, tissue, organ or organism.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000188 "http://edamontology.org/topic_3172")
AnnotationAssertion(rdfs:label obo:FLUXO_0000188 "metabolomics")
SubClassOf(obo:FLUXO_0000188 obo:COB_0000082)

# Class: obo:FLUXO_0000189 (proteomics)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000189 "Proteomics is in the narrow sense (sensu stricto) the application of methods to separate, characterise, identify, and quantify all proteins (the proteome) - or a substantial set of proteins - that are present in a sample. Proteomics in the broad sense is the science of proteins and peptides on the large scale.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000189 "http://edamontology.org/topic_0121")
AnnotationAssertion(rdfs:label obo:FLUXO_0000189 "proteomics")
SubClassOf(obo:FLUXO_0000189 obo:COB_0000082)

# Class: obo:FLUXO_0000190 (mass spectrometry)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000190 "Mass spectrometry is spectrometry where the sample is converted into gaseous ions which are characterised by their mass-to-charge ratio and relative abundance.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000190 "http://purl.obolibrary.org/obo/CHMO_0000470")
AnnotationAssertion(rdfs:label obo:FLUXO_0000190 "mass spectrometry")
SubClassOf(obo:FLUXO_0000190 obo:COB_0000082)

# Class: obo:FLUXO_0000191 (liquid chromatography-mass spectrometry)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000191 "Liquid chromatography-mass spectrometry is a method where a sample mixture is first separated by liquid chromatography before being converted into ions which are characterised by their mass-to-charge ratio and relative abundance.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000191 "http://purl.obolibrary.org/obo/CHMO_0000524")
AnnotationAssertion(rdfs:label obo:FLUXO_0000191 "liquid chromatography-mass spectrometry")
SubClassOf(obo:FLUXO_0000191 obo:FLUXO_0000190)

# Class: obo:FLUXO_0000192 (gas chromatography-mass spectrometry)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000192 "Gas chromatography-mass spectrometry is any method where a sample mixture is first separated by gas chromatography then ionised and characterised according to mass-to-charge ratio and relative abundance.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000192 "http://purl.obolibrary.org/obo/CHMO_0000497")
AnnotationAssertion(rdfs:label obo:FLUXO_0000192 "gas chromatography-mass spectrometry")
SubClassOf(obo:FLUXO_0000192 obo:FLUXO_0000190)

# Class: obo:FLUXO_0000193 (tandem mass spectrometry)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000193 "Tandem mass spectrometry is mass spectrometry involving multiple mass-selection steps, with some form of fragmentation occurring between each stage.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000193 "http://purl.obolibrary.org/obo/CHMO_0000575")
AnnotationAssertion(rdfs:label obo:FLUXO_0000193 "tandem mass spectrometry")
SubClassOf(obo:FLUXO_0000193 obo:FLUXO_0000190)

# Class: obo:FLUXO_0000194 (isotope ratio mass spectrometry)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000194 "Isotope ratio mass spectrometry is mass spectrometry where the relative abundance of isotopes in a sample is determined.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000194 "http://purl.obolibrary.org/obo/CHMO_0000506")
AnnotationAssertion(rdfs:label obo:FLUXO_0000194 "isotope ratio mass spectrometry")
SubClassOf(obo:FLUXO_0000194 obo:FLUXO_0000190)

# Class: obo:FLUXO_0000195 (nuclear magnetic resonance spectroscopy)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000195 "")
AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000195 "A nuclear magnetic resonance method in which the energy states of spin-active nuclei placed in a static magnetic field are interrogated by inducing transitions between the states via radio frequency irradiation.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000195 "http://purl.obolibrary.org/obo/CHMO_0000591")
AnnotationAssertion(rdfs:label obo:FLUXO_0000195 "nuclear magnetic resonance spectroscopy")
SubClassOf(obo:FLUXO_0000195 obo:COB_0000082)

# Class: obo:FLUXO_0000196 (isotope natural abundance correction)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000196 "Isotope natural abundance correction is a data transformation which aims to take into account the contribution of natural random variation in isotopic composition in the environment and adjust for it during the calculation of mass isotopologue distribution in a tracer based metabolomics experiment.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000196 "http://purl.obolibrary.org/obo/MSIO_0000130")
AnnotationAssertion(rdfs:label obo:FLUXO_0000196 "isotope natural abundance correction")
SubClassOf(obo:FLUXO_0000196 obo:OBI_0200000)

# Class: obo:FLUXO_0000197 (concentration)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000197 "A concentration is the measure of the amount of solute dissolved in a unit quantity of solvent or solution. It describes the strength or intensity of a solution in terms of its solute content.  It is therefore a ratio in which the numerator is a measure of the solute and the denominator is a measure of the solvent.")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000197 "http://purl.obolibrary.org/obo/STATO_0000704")
AnnotationAssertion(rdfs:label obo:FLUXO_0000197 "concentration")
SubClassOf(obo:FLUXO_0000197 obo:IAO_0000109)

# Class: obo:FLUXO_0000198 (systems biology representation)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000198 "Systems biology representation is the representation of an entity used in a systems biology knowledge reconstruction, such as a model, pathway, network.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000198 "Sergi: Not a data item. Maybe move to information content entity")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000198 "http://biomodels.net/SBO/SBO_0000000")
AnnotationAssertion(rdfs:label obo:FLUXO_0000198 "systems biology representation")
SubClassOf(obo:FLUXO_0000198 obo:IAO_0000030)

# Class: obo:FLUXO_0000199 (chemical formula)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000199 "A chemical formula is a specification of a chemical structure.")
AnnotationAssertion(obo:IAO_0000116 obo:FLUXO_0000199 "Te: specification is not a data item? It should be a textual information?")
