AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000166 "http://purl.obolibrary.org/obo/MSIO_0000001")
AnnotationAssertion(rdfs:label obo:FLUXO_0000166 "chemical reaction")
SubClassOf(obo:FLUXO_0000166 obo:BFO_0000015)

# Class: obo:FLUXO_0000167 (reactant)

AnnotationAssertion(obo:IAO_0000115 obo:FLUXO_0000167 "A reactant is the starting metabolite of a metabolic reaction.")
AnnotationAssertion(oboInOwl:hasBroadSynonym obo:FLUXO_0000167 "reagent")
AnnotationAssertion(oboInOwl:hasDbXref obo:FLUXO_0000167 "http://biomodels.net/SBO/SBO_0000010")
