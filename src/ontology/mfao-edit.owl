        <obo:IAO_0000115>The transfer of a metabolite or metabolites between two compartments</obo:IAO_0000115>
        <rdfs:label>transport reaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000129 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000129">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
