    <!-- http://purl.obolibrary.org/obo/FLUXO_0000123 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000123">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <obo:IAO_0000115>A data item which represents the speed of a chemical reaction turning reactive species into product species of event (i.e the number of such conversions) occuring over a time interval</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>flux</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>reaction rate</oboInOwl:hasExactSynonym>
        <rdfs:comment>it is commonly refer to flux in MFA, even though formally it is a rate. The actual definition of metabolic flux is the amount of metabolite which is converted per time unit. It is calculated as the reaction rate times stoichiometric coefficient, often normalized to a specific quantity (e.g. cell dry weight or volume of a compartment)</rdfs:comment>
        <rdfs:label>metabolic flux</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000124 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000124">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000123"/>
        <obo:IAO_0000115>The metabolic flux of a metabolic reaction that occurs across metabolic network model boundaries</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>boundary flux</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>external rate</oboInOwl:hasExactSynonym>
        <rdfs:comment>In the FBA field, the exchange flux means the external flux.</rdfs:comment>
        <rdfs:label>external flux</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000125 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000125">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115>a model representation of metabolism</obo:IAO_0000115>
        <rdfs:label>metabolic model</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000126 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000126">
