        <obo:IAO_0000115>a set of interconnected pathways of metabolic reactions within a biological entity</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>network</oboInOwl:hasExactSynonym>
        <rdfs:label>metabolic network</rdfs:label>
    </owl:Class>
    


