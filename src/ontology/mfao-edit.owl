        <obo:IAO_0000115>The chemical compounds of a biological entity are connected by metabolic reactions which convert one compound into another.</obo:IAO_0000115>
        <rdfs:label>metabolism</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000127 -->

