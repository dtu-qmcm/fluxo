#   Classes
############################

# Class: <http://biomodels.net/SBO/SBO_0000010> (reactant)

AnnotationAssertion(obo:IAO_0000115 <http://biomodels.net/SBO/SBO_0000010> "Starting metabolite of a metabolic reaction")
AnnotationAssertion(oboInOwl:hasBroadSynonym <http://biomodels.net/SBO/SBO_0000010> "reagent")
AnnotationAssertion(oboInOwl:hasExactSynonym <http://biomodels.net/SBO/SBO_0000010> "educt")
AnnotationAssertion(rdfs:label <http://biomodels.net/SBO/SBO_0000010> "reactant")
SubClassOf(<http://biomodels.net/SBO/SBO_0000010> obo:CHEBI_25212)

# Class: <http://biomodels.net/SBO/SBO_0000011> (product)

AnnotationAssertion(obo:IAO_0000115 <http://biomodels.net/SBO/SBO_0000011> "Product metabolite of a metabolic reaction")
AnnotationAssertion(rdfs:label <http://biomodels.net/SBO/SBO_0000011> "product")
SubClassOf(<http://biomodels.net/SBO/SBO_0000011> obo:CHEBI_25212)

