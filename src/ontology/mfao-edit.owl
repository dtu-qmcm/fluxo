        <disjointWith rdf:resource="http://w3id.org/msio/MSIO_0000151"/>
        <obo:IAO_0000115>Net rate at which a metabolic reaction proceeds in nominal direction within a living biological system</obo:IAO_0000115>
        <rdfs:label>intracellular flux</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/MFAO_0000003 -->

