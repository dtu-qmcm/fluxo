        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000146"/>
        <obo:IAO_0000115>A state-space representation that models positional labeling by a state (0: unlabeled, 1: labeled or x: either labeled or unlabeled).</obo:IAO_0000115>
        <rdfs:label>Cumomer Representation</rdfs:label>
    </owl:Class>
    


