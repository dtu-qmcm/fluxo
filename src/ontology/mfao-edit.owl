############################
#   Object Properties
############################

# Object Property: obo:MFAO_0000004 (reaction bidirectionality)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000004 "A characteristic of a biochemical reaction which proceeds simultaneously in forward and backward direction")
AnnotationAssertion(rdfs:label obo:MFAO_0000004 "reaction bidirectionality")
ObjectPropertyDomain(obo:MFAO_0000004 obo:MFAO_0000003)

# Object Property: obo:MFAO_0000006 (has_flux)

AnnotationAssertion(rdfs:label obo:MFAO_0000006 "has_flux")
ObjectPropertyDomain(obo:MFAO_0000006 obo:MFAO_0000003)
ObjectPropertyRange(obo:MFAO_0000006 <http://w3id.org/msio/MSIO_0000150>)

# Object Property: obo:MFAO_0000007 (has_reactant)

AnnotationAssertion(rdfs:label obo:MFAO_0000007 "has_reactant")
ObjectPropertyDomain(obo:MFAO_0000007 obo:MFAO_0000003)
ObjectPropertyRange(obo:MFAO_0000007 obo:NCIT_C43366)

# Object Property: obo:MFAO_0000008 (has_product)

AnnotationAssertion(rdfs:label obo:MFAO_0000008 "has_product")
ObjectPropertyDomain(obo:MFAO_0000008 obo:MFAO_0000003)
ObjectPropertyRange(obo:MFAO_0000008 obo:NCIT_C43366)

# Object Property: obo:MFAO_0000009 (has_nominal_direction)

AnnotationAssertion(rdfs:label obo:MFAO_0000009 "has_nominal_direction")
ObjectPropertyDomain(obo:MFAO_0000009 obo:MFAO_0000011)
ObjectPropertyRange(obo:MFAO_0000009 obo:MFAO_0000012)


############################
#   Data Properties
############################

# Data Property: obo:MFAO_0000004 (reaction bidirectionality)

DataPropertyRange(obo:MFAO_0000004 xsd:boolean)

# Data Property: obo:MFAO_0000005 (reaction reversibility)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000005 "The property of metabolic reaction to proceed in forward and backward direction")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:MFAO_0000005 "reaction bidirectionality")
AnnotationAssertion(rdfs:comment obo:MFAO_0000005 "property or class")
AnnotationAssertion(rdfs:label obo:MFAO_0000005 "reaction reversibility")
DataPropertyDomain(obo:MFAO_0000005 obo:MFAO_0000003)
DataPropertyRange(obo:MFAO_0000005 xsd:boolean)

# Data Property: <http://w3id.org/msio/MSIO_0000070> (metabolite pool size estimate)

AnnotationAssertion(rdfs:label <http://w3id.org/msio/MSIO_0000070> "metabolite pool size estimate")
DataPropertyDomain(<http://w3id.org/msio/MSIO_0000070> obo:CHEBI_25212)
DataPropertyRange(<http://w3id.org/msio/MSIO_0000070> xsd:double)



