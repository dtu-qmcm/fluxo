    <!-- http://purl.obolibrary.org/obo/BFO_0000008 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000008"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000015"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000019 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000019"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000027 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000027"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000028 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000028"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000031 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000031"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000040 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000141 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000141"/>
    


    <!-- http://purl.obolibrary.org/obo/COB_0000026 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/COB_0000026"/>
    


    <!-- http://purl.obolibrary.org/obo/COB_0000082 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/COB_0000082"/>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000141"/>
        <obo:IAO_0000115>The complete set of metabolic fluxes (reaction rates) in a biological system at a given point in time.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>fluxomics</oboInOwl:hasBroadSynonym>
        <rdfs:label>fluxome</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <obo:IAO_0000115>the data that contains files to determine the rates of metabolic reactions. It generally includes the model of metabolic networks and experimental data</obo:IAO_0000115>
        <rdfs:label>fluxomics data</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000123"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000124"/>
        <obo:IAO_0000115>The metabolic flux of a metabolic reaction that occurs within a metabolic network model</obo:IAO_0000115>
        <rdfs:label>internal flux</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000004 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000004">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000123"/>
        <obo:IAO_0000115>The metabolic flux of a transport reaction</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>transport rate</oboInOwl:hasExactSynonym>
        <rdfs:label>transport flux</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000005 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000166"/>
        <obo:IAO_0000115>biochemical reaction within a biological entity that is part of the metabolism.</obo:IAO_0000115>
        <rdfs:label>metabolic reaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000006 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <obo:IAO_0000115>A characteristic of a biochemical reaction which may proceed simultaneously in forward and backward direction</obo:IAO_0000115>
        <rdfs:label>reaction bidirectionality</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <obo:IAO_0000115>The property of metabolic reaction to proceed in forward and backward direction</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>reaction bidirectionality</oboInOwl:hasExactSynonym>
        <rdfs:comment>property could be 0 or 1 (True or False)</rdfs:comment>
        <rdfs:label>reaction reversibility</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000008 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000005"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000009"/>
        <obo:IAO_0000115>A metabolic reaction that solely operates in a single direction, it can be forward or backward direction.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>irreversible reaction</oboInOwl:hasExactSynonym>
        <rdfs:comment>property or class</rdfs:comment>
        <rdfs:label>unidirectional reaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000009 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000009">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000005"/>
        <obo:IAO_0000115>A metabolic reaction that may operate simultaneously in forward and backward direction.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>reversible reaction</oboInOwl:hasExactSynonym>
        <rdfs:comment>property or class</rdfs:comment>
        <rdfs:label>bidirectional reaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000010">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <obo:IAO_0000115>the direction of the reaction operates</obo:IAO_0000115>
        <rdfs:label>reaction direction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000011 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000011">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000005"/>
        <obo:IAO_0000115>the reaction that proceeds from substrates to products</obo:IAO_0000115>
        <rdfs:label>forward reaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000012 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000005"/>
        <obo:IAO_0000115>the reaction that proceeds from products to substrates</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>reverse direction</oboInOwl:hasExactSynonym>
        <rdfs:label>backward reaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000013 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000013">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000010"/>
        <obo:IAO_0000115>the reaction that the rate of the forward reaction equals the rate of the backward reaction</obo:IAO_0000115>
        <rdfs:label>equilibrium</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000014 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000014">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000172"/>
        <obo:IAO_0000115>metabolites which are only consumed, typically the substrate(s)</obo:IAO_0000115>
        <rdfs:label>source</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000172"/>
        <obo:IAO_0000115>metabolites which are only produced, typically the by-product(s)</obo:IAO_0000115>
        <rdfs:label>sink</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000016 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000016">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <obo:IAO_0000115>Quantitative visualization of reaction fluxes within a metabolic network, typically scaled by flux magnitude and annotated with directionality.</obo:IAO_0000115>
        <rdfs:label>flux map</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000017 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000017">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <obo:IAO_0000115>the specific pattern or distribution of metabolic fluxes within a biological system, such as a cell or organism, under defined conditions.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>flux state</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>metabolic flux phenotype</oboInOwl:hasExactSynonym>
        <rdfs:label>fluxotype</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000018 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000018">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000162"/>
        <obo:IAO_0000115>Set of mathemetical approaches for characterizing metabolic states that constrain the possible flux space given a reaction stoichiometry</obo:IAO_0000115>
        <rdfs:label>stoichiometry-based fluxomics method</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000019 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000019">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000018"/>
        <obo:IAO_0000115>Set of mathematical approaches in which the possible fluxes are constrained by a minimum and maximum range of bounds, and further restrictions such as the reaction stoichiometry or objectives</obo:IAO_0000115>
        <rdfs:label>constraint-based fluxomics method</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000020 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000020">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000162"/>
        <obo:IAO_0000115>A methodology that determines metabolic fluxes within a cell based on empirical data.</obo:IAO_0000115>
        <rdfs:label>flux measurement method</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000021 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000021">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000020"/>
        <obo:IAO_0000115>Set of approaches that quantitatively estimate/infer metabolic fluxes using a metabolic reaction model, experimental data and computation</obo:IAO_0000115>
        <rdfs:label>metabolic flux analysis method</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000022 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000022">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115>Set of all possible flux vectors that are consistent with reaction stoichiometries and a set of flux constraints at metabolic steady state</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>flux polytope</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>flux solution space</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>flux space</oboInOwl:hasExactSynonym>
        <rdfs:label>steady state flux solution space</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000023 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000023">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115>List of the rates of all chemical reactions in a biological network</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>flux distribution</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>flux state</oboInOwl:hasExactSynonym>
        <rdfs:label>flux vector</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000024 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000024">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000057"/>
        <obo:IAO_0000115>a mathematical representation of a cellular metabolic network that relies on the conservation of mass rather than enzyme kinetics to predict metabolic behavior.</obo:IAO_0000115>
        <rdfs:label>stoichiometric reaction model</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000025 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000025">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000123"/>
        <obo:IAO_0000115>A rate at which a specific reaction proceeds in the forward direction.</obo:IAO_0000115>
        <rdfs:comment>non-negative</rdfs:comment>
        <rdfs:label>forward flux</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000026 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000026">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000123"/>
        <obo:IAO_0000115>A rate at which a specific reaction proceeds in the backward direction.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>reverse flux</oboInOwl:hasExactSynonym>
        <rdfs:comment>non-negative</rdfs:comment>
        <rdfs:label>backward flux</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000027 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000027">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000123"/>
        <obo:IAO_0000115>Difference between the forward and backward flux for a metabolic reaction.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>net rate</oboInOwl:hasExactSynonym>
        <rdfs:label>net flux</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000028 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000028">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000123"/>
        <obo:IAO_0000115>The minimum of the forward and backward fluxes of a metabolic reaction.</obo:IAO_0000115>
        <rdfs:comment>non-negative; This is different from exchange flux in flux balance analysis (make note in ontology)</rdfs:comment>
        <rdfs:label>exchange flux</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000029 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000029">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115>Relative proportion of metabolic flow directed into a specific pathway at a divergence point compared to the total flow or an alternative route at that same junction.</obo:IAO_0000115>
        <rdfs:label>flux ratio</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000030 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000030">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <obo:IAO_0000115>The number of free/independent fluxes that can be varied independently within the network, which is determined by the null space of the stoichiometric matrix. The dimension of this null space gives the number of fluxes needed to define all other fluxes.</obo:IAO_0000115>
        <rdfs:label>degrees of freedom in stoichiometry matrix</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000031 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000031">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000170"/>
        <obo:IAO_0000115>One of several species (or molecular entities) that have the same atomic composition (molecular formula) but different line formulae or different stereochemical formulae and hence different physical and/or chemical properties.</obo:IAO_0000115>
        <rdfs:label>isomer</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000032 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000032">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <obo:IAO_0000115>The specific distribution of istopic atom in a metabolite pools at specific time</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>metabolite labeling pattern</oboInOwl:hasExactSynonym>
        <rdfs:label>isotopic labeling state</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000033 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000033">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <obo:IAO_0000115>The assumption that the rate of change of an intracellular metabolite concentration is considered negligible, which holds when the metabolic flux through the metabolite pools is much larger than the change in their pool sizes over time</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>Metabolic Pseudo-Steady State</oboInOwl:hasExactSynonym>
        <rdfs:label>pseudo-steady state assumption</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000034 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000034">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000177"/>
        <obo:IAO_0000115>An idealistic state in which both metabolic fluxes and intracellular metabolite pool sizes are approximately constant over time.</obo:IAO_0000115>
        <rdfs:label>metabolic steady state</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000035 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000035">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <obo:IAO_0000115>The dynamic phase of an isotopic labeling experiment where metabolite labeling patterns are not yet constant.</obo:IAO_0000115>
        <rdfs:label>isotopic transient state</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000036 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000036">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000177"/>
        <obo:IAO_0000115>A state when the distribution of a stable isotope label within a biological system has become and remains constant over time.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>isotopic steady state</oboInOwl:hasExactSynonym>
        <rdfs:label>isotopic steady state</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000037 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000037">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000082"/>
        <obo:IAO_0000115>A stochastic process for characterizing the range of possible/feasible metabolic flux vectors.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>flux state sampling</oboInOwl:hasExactSynonym>
        <rdfs:label>flux space sampling</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000038 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000038">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000082"/>
        <obo:IAO_0000115>A technique that determines the possible fluxes of the metabolic reactions in a network</obo:IAO_0000115>
        <rdfs:label>fluxomics method</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000039 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000039">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000038"/>
        <obo:IAO_0000115>A method that predicts physiological phenotypes allowed by the underlying metabolic model, typically enforced by a metabolic goal (e.g., maximize growth rate).</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>FBA</oboInOwl:hasExactSynonym>
        <rdfs:label>flux balance analysis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000040 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000040">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000038"/>
        <obo:IAO_0000115>A quantitative strategy based on a metabolic network and experimental data to determine intracellular reaction rates (fluxes) with the highest possible accuracy.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>MFA</oboInOwl:hasExactSynonym>
        <rdfs:label>metabolic flux analysis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000041 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000041">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000040"/>
        <obo:IAO_0000115>A set of methods used to measure the rates of intracellular metabolic reactions in living cells using data from isotope labeling experiments</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>I-MFA</oboInOwl:hasExactSynonym>
        <rdfs:label>isotope-based metabolic flux analysis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000042 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000042">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000041"/>
        <obo:IAO_0000115>A method for estimating metabolic fluxes by tracking from the distribution of 13C isotopes in metabolites.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>13C-MFA</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>13C-based metabolic flux analysis</oboInOwl:hasExactSynonym>
        <rdfs:label>13C metabolic flux analysis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000043 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000043">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000041"/>
        <obo:IAO_0000115>Isotope-based metabolic flux analysis technique, assuming isotopic steady state and metabolic steady state</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>IST-MFA</oboInOwl:hasExactSynonym>
        <rdfs:label>isotopically stationary metabolic flux analysis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000044 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000044">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000045"/>
        <obo:IAO_0000115>Isotope-based metabolic flux analysis technique, assuming isotopic transient state and metabolic steady state</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>INST-13C-MFA</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>INST-MFA</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>Isotopic Non-Stationary MFA</oboInOwl:hasExactSynonym>
        <rdfs:label>isotopically non-stationary metabolic flux analysis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000045 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000045">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000041"/>
        <obo:IAO_0000115>Isotope-based metabolic flux analysis technique, assuming both isotopic and metabolic dynamic state</obo:IAO_0000115>
        <rdfs:label>dynamic Isotope-based metabolic flux analysis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000046 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000046">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000178"/>
        <obo:IAO_0000115>Approaches to increase the information content of an isotope labeling experiment</obo:IAO_0000115>
        <rdfs:label>isotope labeling experiment design</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000047 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000047">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000046"/>
        <obo:IAO_0000115>Computational approaches to targeted improvement of the information gain of an isotope labeling experiment</obo:IAO_0000115>
        <rdfs:label>optimal isotope labeling experimental design</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000048 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000048">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000046"/>
        <obo:IAO_0000115>Strategic choice of isotopic tracer (molecule, labeling position, isotope) based on target pathway thermodynamics and atom transitions.</obo:IAO_0000115>
        <rdfs:label>tracer selection</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000049 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000049">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000162"/>
        <obo:IAO_0000115>An experiment where biological entities are fed stable isotopic tracers (like 13C) which are then distributed throughout the metabolic network via metabolic activity.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>ILE</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>SIL</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>SILE</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>Stable-isotope labeling experiment</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasExactSynonym>fluxomics stable isotope labeling experiment</oboInOwl:hasExactSynonym>
        <rdfs:label>fluxomics isotope labeling experiment</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000050 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000050">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000049"/>
        <obo:IAO_0000115>Multiple experiments where different isotopic tracers with distinct labeling patterns or tracer mixtures are supplied to resolve overlapping metabolic routes</obo:IAO_0000115>
        <rdfs:label>parallel labeling experiments</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000051 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000051">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000049"/>
        <obo:IAO_0000115>One labeling experiment where a single tracer or tracer mixture is supplied</obo:IAO_0000115>
        <rdfs:label>single labeling experiment</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000052 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000052">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000170"/>
        <obo:IAO_0000115>A charged dissociation product of a molecule generated during mass spectrometry, providing specific positional labeling information.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>Daughter ion</oboInOwl:hasExactSynonym>
        <rdfs:label>fragment ion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000053 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000053">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000170"/>
        <obo:IAO_0000115>The ion selected for fragmentation in tandem mass spectrometry (MS/MS).</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>Parent ion</oboInOwl:hasExactSynonym>
        <rdfs:label>precursor ion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000054 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000054">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000143"/>
        <obo:IAO_0000115>A measurement of the relative abundance of different isotopomers in both a parent molecule and its fragments, obtained through tandem mass spectrometry (MS/MS)</obo:IAO_0000115>
        <rdfs:label>tandem isotopologue distribution</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000055 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000055">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <obo:IAO_0000115>The percentage of molecules in a given metabolite pool that contain one or more isotopic labels from a tracer.</obo:IAO_0000115>
        <rdfs:label>fractional enrichment</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000056 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000056">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000008"/>
        <obo:IAO_0000115>The time where a sample is taken from the biological experiment for analysis.</obo:IAO_0000115>
        <rdfs:label>measurement time</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000057 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000057">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115>The computational representation of biochemical reactions within a cell, which includes their molecules, stoichiometries, directionalities, and in MFA, constraints and atom transitions.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>metabolic model</oboInOwl:hasExactSynonym>
        <rdfs:label>metabolic network model</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000058 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000058">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000028"/>
        <obo:IAO_0000115>A physically or functionally distinct space (e.g., Cytosol, Mitochondria, Metabolon)</obo:IAO_0000115>
        <rdfs:label>compartment</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000059 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000059">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000198"/>
        <obo:IAO_0000115>The stoichiometric representation of cellular macromolecules (e.g. Protein, DNA, RNA, Lipids).</obo:IAO_0000115>
        <rdfs:label>biomass composition</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000060 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000060">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000198"/>
        <obo:IAO_0000115>A set of one or several metabolites</obo:IAO_0000115>
        <rdfs:label>metabolite pool</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000061 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000061">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000198"/>
        <obo:IAO_0000115>a metabolic pool in the metabolic network that does not have any biological counterpart and is purely introduced for modeling reason</obo:IAO_0000115>
        <rdfs:label>pseudo metabolite pool</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000062 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000062">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <obo:IAO_0000115>An amount of molecular entity available to a particular metabolic process.</obo:IAO_0000115>
        <rdfs:label>metabolite pool size</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000063 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000063">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <obo:IAO_0000115>A set of chemical reactions that is part of the metabolic network model</obo:IAO_0000115>
        <rdfs:label>reaction pool</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000064 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000064">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <obo:IAO_0000115>A property of molecules where certain atoms are chemically indistinguishable, making a unique atom numbering impossible.</obo:IAO_0000115>
        <rdfs:label>symmetry</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000065 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000065">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000005"/>
        <obo:IAO_0000115>a reaction in the metabolic network that does not have any biological counterpart and is purely introduced for modeling reason.</obo:IAO_0000115>
        <rdfs:label>pseudo reaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000066 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000066">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000065"/>
        <obo:IAO_0000115>A simplified reaction that merge multiple chemical reactions into a single reaction for modeling reason.</obo:IAO_0000115>
        <rdfs:label>lumped reaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000067 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000067">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000065"/>
        <obo:IAO_0000115>An abstract reaction that represents consumption of metabolites for cellular growth in a metabolic model</obo:IAO_0000115>
        <rdfs:label>biomass reaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000068 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000068">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <obo:IAO_0000115>The limits on metabolic flux value on reactions</obo:IAO_0000115>
        <rdfs:label>linear flux constraint</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000069 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000069">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <obo:IAO_0000115>A unique position to atoms in a molecule to track its position within the molecule.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>atom address</oboInOwl:hasExactSynonym>
        <rdfs:comment>https://www.inchi-trust.org/download/104/InChI_TechMan.pdf</rdfs:comment>
        <rdfs:label>atom identifier</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000070 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000070">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000027"/>
        <obo:IAO_0000115>The precise mapping of how each relevant atom in a substrate is rearranged to form the product metabolites during a reaction. It usually excludes hydrogens.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>atom transition</oboInOwl:hasExactSynonym>
        <rdfs:label>atom mapping</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000071 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000071">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000027"/>
        <obo:IAO_0000115>Set of atom maps for all reactions making up a metabolic network model</obo:IAO_0000115>
        <rdfs:label>atom transition network</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000072 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000072">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <obo:IAO_0000115>The annotation types for atom transition.</obo:IAO_0000115>
        <rdfs:label>atom transition annotation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000073 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000073">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000072"/>
        <obo:IAO_0000115>An annotation that uses a-z and A-Z to represent the order of the tracked atoms in a molecule</obo:IAO_0000115>
        <rdfs:label>letter annotation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000074 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000074">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000072"/>
        <obo:IAO_0000115>An annotation that uses FluxML definition to track atom mapping in a reaction</obo:IAO_0000115>
        <rdfs:label>fluxml annotation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000075 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000075">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000072"/>
        <obo:IAO_0000115>An annotation that uses InChI specification to track atoms in a reaction</obo:IAO_0000115>
        <rdfs:label>InChI annotation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000076 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000076">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000072"/>
        <obo:IAO_0000115>An annotation that uses SMILE specification to track atoms in a reaction</obo:IAO_0000115>
        <rdfs:label>SMILE annotation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000077 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000077">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000155"/>
        <obo:IAO_0000115>An atom mapping that represents the complementary atom transition in a reaction that involves symmetric compound.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>scrambling</oboInOwl:hasExactSynonym>
        <rdfs:label>symmetric atom transition</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000078 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000078">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000026"/>
        <obo:IAO_0000115>A blend of differentially labeled substrate isotopomers (e.g., % [1-¹³C]glucose + % [U-¹³C]glucose) administered in an ILE</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>commercial isotopically labelled molecular entity mixture</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>tracer mixture</oboInOwl:hasExactSynonym>
        <rdfs:label>labelled source</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000079 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000079">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <obo:IAO_0000115>The characteristics of the isotopic tracer</obo:IAO_0000115>
        <rdfs:label>isotopic tracer property</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000080 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000080">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000079"/>
        <obo:IAO_0000115>The purity of the isotopic tracer specified in the label input</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>isotopic purity</oboInOwl:hasExactSynonym>
        <rdfs:label>label input isotopic purity</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000081 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000081">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000079"/>
        <obo:IAO_0000115>The price of the isotopic tracer molecular entity</obo:IAO_0000115>
        <rdfs:label>tracer cost</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000083 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000083">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000109"/>
        <obo:IAO_0000115>The rate of biomass formation</obo:IAO_0000115>
        <rdfs:label>growth rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000084 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000084">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000083"/>
        <obo:IAO_0000115>the biomass increase per unit of existing biomass per unit of time</obo:IAO_0000115>
        <rdfs:label>specific growth rate</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000085 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000085">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000109"/>
        <obo:IAO_0000115>Efficiency of substrate conversion into product/biomass (mass or molar basis).</obo:IAO_0000115>
        <rdfs:label>yield</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000086 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000086">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000207"/>
        <obo:IAO_0000115>A measure used in flux estimation, specifically the variance-weighted sum of squares residuals, which is minimized to quantify fluxes. It serves as a key indicator of goodness-ofreflect the certainty with which metabolic fluxes were determined.</obo:IAO_0000115>
        <rdfs:label>weighted sum of squared residuals</rdfs:label>
    </owl:Class>
    


