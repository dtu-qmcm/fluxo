        <rdfs:label>pseudomolecule</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000130 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000130">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000028"/>
        <obo:IAO_0000115>The minimum of the forward and backward fluxes of a metabolic reaction, calculated by convention as a/(1+a), where a is the exchange flux.</obo:IAO_0000115>
        <rdfs:label>relative exchange flux</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000131 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FLUXO_0000131">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000174"/>
