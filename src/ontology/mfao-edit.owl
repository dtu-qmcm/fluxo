        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <obo:IAO_0000115>a biochemical reaction within a living organism and is part of the metabolism.</obo:IAO_0000115>
        <rdfs:label>metabolic reaction</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/MFAO_0000010 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/MFAO_0000010">
        <equivalentClass>
            <Class>
                <intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/MFAO_0000003"/>
                    <Restriction>
                        <onProperty rdf:resource="http://purl.obolibrary.org/obo/MFAO_0000005"/>
                        <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</hasValue>
                    </Restriction>
                </intersectionOf>
            </Class>
        </equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MFAO_0000003"/>
        <disjointWith rdf:resource="http://purl.obolibrary.org/obo/MFAO_0000011"/>
        <obo:IAO_0000115>A metabolic reaction that solely operates in a single direction, from educts to products</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>irreversible reaction</oboInOwl:hasExactSynonym>
        <rdfs:comment>property or class</rdfs:comment>
        <rdfs:label>unidirectional reaction</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/MFAO_0000011 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/MFAO_0000011">
        <equivalentClass>
            <Class>
                <intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/MFAO_0000003"/>
                    <Restriction>
                        <onProperty rdf:resource="http://purl.obolibrary.org/obo/MFAO_0000005"/>
                        <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hasValue>
                    </Restriction>
                </intersectionOf>
            </Class>
        </equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MFAO_0000003"/>
        <obo:IAO_0000115>A metabolic reaction that operates simultaneously in forward and backward direction.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>reversible reaction</oboInOwl:hasExactSynonym>
        <rdfs:comment>property or class</rdfs:comment>
        <rdfs:label>bidirectional reaction</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/MFAO_0000012 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/MFAO_0000012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <obo:IAO_0000115>A net path that a chemical system to reach or maintain a state of equilbrium</obo:IAO_0000115>
        <rdfs:label>reaction direction</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/MFAO_0000013 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/MFAO_0000013">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MFAO_0000012"/>
        <obo:IAO_0000115>the reaction that proceeds from educts to products</obo:IAO_0000115>
        <rdfs:label>forward direction</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/MFAO_0000014 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/MFAO_0000014">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MFAO_0000012"/>
        <obo:IAO_0000115>the reaction that proceeds from products to educts</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>reverse direction</oboInOwl:hasExactSynonym>
        <rdfs:label>backward direction</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/MFAO_0000015 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/MFAO_0000015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MFAO_0000012"/>
        <obo:IAO_0000115>the reaction that the rate of the forward reaction equals the rate of the backward reaction</obo:IAO_0000115>
        <rdfs:label>equilibrium</rdfs:label>
    </Class>
    


    <!-- http://purl.obolibrary.org/obo/MFAO_0000016 -->

    <Class rdf:about="http://purl.obolibrary.org/obo/MFAO_0000016">
