     xml:base="http://purl.obolibrary.org/obo/mfao/components/definitions.owl"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="http://purl.obolibrary.org/obo/mfao/components/definitions.owl">
        <owl:versionIRI rdf:resource="http://purl.obolibrary.org/obo/mfao/releases/2026-03-26/components/definitions.owl"/>
        <owl:versionInfo>2026-03-26</owl:versionInfo>
    </owl:Ontology>
    


