SubClassOf(obo:CHEBI_25212 obo:NCIT_C43366)

# Class: obo:MFAO_0000000 (fluxome)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000000 "The complete set of metabolic fluxes (reaction rates) in a biological system at a given point in time.")
AnnotationAssertion(rdfs:label obo:MFAO_0000000 "fluxome")
SubClassOf(obo:MFAO_0000000 obo:BFO_0000141)

# Class: obo:MFAO_0000001 (fluxomics)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000001 "Experimental approaches to determine the rates of metabolic reactions - the metabolic fluxes - within a biological entity.")
AnnotationAssertion(rdfs:label obo:MFAO_0000001 "fluxomics")

# Class: obo:MFAO_0000002 (intracellular flux)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000002 "Net rate at which a metabolic reaction proceeds in nominal direction within a living biological system")
AnnotationAssertion(rdfs:label obo:MFAO_0000002 "intracellular flux")
SubClassOf(obo:MFAO_0000002 <http://w3id.org/msio/MSIO_0000150>)
DisjointClasses(obo:MFAO_0000002 <http://w3id.org/msio/MSIO_0000151>)

# Class: obo:MFAO_0000003 (metabolic reaction)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000003 "a biochemical reaction within a living organism and is part of the metabolism.")
AnnotationAssertion(rdfs:label obo:MFAO_0000003 "metabolic reaction")
SubClassOf(obo:MFAO_0000003 obo:BFO_0000015)

# Class: obo:MFAO_0000010 (unidirectional reaction)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000010 "A metabolic reaction that solely operates in a single direction, from educts to products")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:MFAO_0000010 "irreversible reaction")
AnnotationAssertion(rdfs:comment obo:MFAO_0000010 "property or class")
AnnotationAssertion(rdfs:label obo:MFAO_0000010 "unidirectional reaction")
EquivalentClasses(obo:MFAO_0000010 ObjectIntersectionOf(obo:MFAO_0000003 DataHasValue(obo:MFAO_0000005 "false"^^xsd:boolean)))
SubClassOf(obo:MFAO_0000010 obo:MFAO_0000003)
DisjointClasses(obo:MFAO_0000010 obo:MFAO_0000011)

# Class: obo:MFAO_0000011 (bidirectional reaction)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000011 "A metabolic reaction that operates simultaneously in forward and backward direction.")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:MFAO_0000011 "reversible reaction")
AnnotationAssertion(rdfs:comment obo:MFAO_0000011 "property or class")
AnnotationAssertion(rdfs:label obo:MFAO_0000011 "bidirectional reaction")
EquivalentClasses(obo:MFAO_0000011 ObjectIntersectionOf(obo:MFAO_0000003 DataHasValue(obo:MFAO_0000005 "true"^^xsd:boolean)))
SubClassOf(obo:MFAO_0000011 obo:MFAO_0000003)

# Class: obo:MFAO_0000012 (reaction direction)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000012 "A net path that a chemical system to reach or maintain a state of equilbrium")
AnnotationAssertion(rdfs:label obo:MFAO_0000012 "reaction direction")
SubClassOf(obo:MFAO_0000012 obo:BFO_0000020)

# Class: obo:MFAO_0000013 (forward direction)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000013 "the reaction that proceeds from educts to products")
AnnotationAssertion(rdfs:label obo:MFAO_0000013 "forward direction")
SubClassOf(obo:MFAO_0000013 obo:MFAO_0000012)

# Class: obo:MFAO_0000014 (backward direction)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000014 "the reaction that proceeds from products to educts")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:MFAO_0000014 "reverse direction")
AnnotationAssertion(rdfs:label obo:MFAO_0000014 "backward direction")
SubClassOf(obo:MFAO_0000014 obo:MFAO_0000012)

# Class: obo:MFAO_0000015 (equilibrium)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000015 "the reaction that the rate of the forward reaction equals the rate of the backward reaction")
AnnotationAssertion(rdfs:label obo:MFAO_0000015 "equilibrium")
SubClassOf(obo:MFAO_0000015 obo:MFAO_0000012)

# Class: obo:MFAO_0000016 (flux map)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000016 "Quantitative visualization of reaction fluxes within a metabolic network, typically scaled by flux magnitude and annotated with directionality.")
AnnotationAssertion(rdfs:label obo:MFAO_0000016 "flux map")
SubClassOf(obo:MFAO_0000016 obo:BFO_0000031)

# Class: obo:MFAO_0000017 (fluxotype)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000017 "the specific pattern or distribution of metabolic fluxes within a biological system, such as a cell or organism, under defined conditions.")
AnnotationAssertion(rdfs:label obo:MFAO_0000017 "fluxotype")
SubClassOf(obo:MFAO_0000017 obo:BFO_0000031)

# Class: obo:MFAO_0000018 (stoichiometry-based fluxomics method)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000018 "Set of mathemetical approaches for characterizing metabolic states that constrain the possible flux space given a reaction stoichiometry")
AnnotationAssertion(rdfs:label obo:MFAO_0000018 "stoichiometry-based fluxomics method")
SubClassOf(obo:MFAO_0000018 <http://w3id.org/msio/MSIO_0000182>)

# Class: obo:MFAO_0000019 (constraint-based fluxomics method)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000019 "Set of mathematical approaches in which the possible fluxes are constrained by a minimum and maximum range of bounds, and further restrictions such as the reaction stoichiometry or objectives")
AnnotationAssertion(rdfs:label obo:MFAO_0000019 "constraint-based fluxomics method")
SubClassOf(obo:MFAO_0000019 obo:MFAO_0000018)

# Class: obo:MFAO_0000020 (flux measurement method)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000020 "A methodology that determines metabolic fluxes within a cell based on empirical data.")
AnnotationAssertion(rdfs:label obo:MFAO_0000020 "flux measurement method")
SubClassOf(obo:MFAO_0000020 <http://w3id.org/msio/MSIO_0000182>)

# Class: obo:MFAO_0000021 (metabolic flux analysis method)

AnnotationAssertion(obo:IAO_0000115 obo:MFAO_0000021 "Set of approaches that quantitatively estimate/infer metabolic fluxes using a metabolic reaction model, experimental data and computation")
AnnotationAssertion(rdfs:label obo:MFAO_0000021 "metabolic flux analysis method")
SubClassOf(obo:MFAO_0000021 obo:MFAO_0000020)

# Class: obo:NCIT_C43366 (compound)

AnnotationAssertion(rdfs:label obo:NCIT_C43366 "compound")
SubClassOf(obo:NCIT_C43366 obo:BFO_0000040)

# Class: <http://w3id.org/msio/MSIO_0000058> (metabolic network)

AnnotationAssertion(obo:IAO_0000115 <http://w3id.org/msio/MSIO_0000058> "a set of interconnected pathways of biochemical reactions within living cells ")
AnnotationAssertion(oboInOwl:hasExactSynonym <http://w3id.org/msio/MSIO_0000058> "network")
AnnotationAssertion(rdfs:label <http://w3id.org/msio/MSIO_0000058> "metabolic network")
SubClassOf(<http://w3id.org/msio/MSIO_0000058> obo:BFO_0000031)

# Class: <http://w3id.org/msio/MSIO_0000059> (metabolic pathway)

AnnotationAssertion(obo:IAO_0000115 <http://w3id.org/msio/MSIO_0000059> "a series of connected biochemical reactions catalyzed by enzymes")
AnnotationAssertion(oboInOwl:hasExactSynonym <http://w3id.org/msio/MSIO_0000059> "pathway")
AnnotationAssertion(rdfs:comment <http://w3id.org/msio/MSIO_0000059> "metabolic network")
AnnotationAssertion(rdfs:label <http://w3id.org/msio/MSIO_0000059> "metabolic pathway")
SubClassOf(<http://w3id.org/msio/MSIO_0000059> obo:BFO_0000031)

# Class: <http://w3id.org/msio/MSIO_0000150> (metabolic flux)

AnnotationAssertion(obo:IAO_0000115 <http://w3id.org/msio/MSIO_0000150> "Rate of metabolite flow through a biochemical reaction")
AnnotationAssertion(oboInOwl:hasExactSynonym <http://w3id.org/msio/MSIO_0000150> "flux")
AnnotationAssertion(oboInOwl:hasExactSynonym <http://w3id.org/msio/MSIO_0000150> "metabolic reaction rate")
AnnotationAssertion(rdfs:comment <http://w3id.org/msio/MSIO_0000150> "fluxome")
AnnotationAssertion(rdfs:label <http://w3id.org/msio/MSIO_0000150> "metabolic flux")
SubClassOf(<http://w3id.org/msio/MSIO_0000150> obo:BFO_0000144)

# Class: <http://w3id.org/msio/MSIO_0000151> (extracellular flux)

AnnotationAssertion(rdfs:label <http://w3id.org/msio/MSIO_0000151> "extracellular flux")
SubClassOf(<http://w3id.org/msio/MSIO_0000151> <http://w3id.org/msio/MSIO_0000150>)

# Class: <http://w3id.org/msio/MSIO_0000182> (fluxomics investigation)

AnnotationAssertion(rdfs:label <http://w3id.org/msio/MSIO_0000182> "fluxomics investigation")
SubClassOf(<http://w3id.org/msio/MSIO_0000182> obo:BFO_0000015)


