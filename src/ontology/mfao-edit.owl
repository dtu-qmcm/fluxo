        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FLUXO_0000146"/>
        <obo:IAO_0000115>A state-space representation that models positional labeling by a binary number (0: non-labeled, 1: labeled).</obo:IAO_0000115>
        <rdfs:label>Isotopomer Representation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FLUXO_0000149 -->

